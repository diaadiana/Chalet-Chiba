---
---
<section class="hero" id="hero">
  <div class="hero-video-wrap">
    <video class="hero-bg hero-vid" autoplay muted loop playsinline preload="auto">
      <source src="/hero-video.mp4" type="video/mp4">
    </video>
  </div>
  <div class="hero-ov"></div>

  <div class="hero-bottom">
    <div class="hb-left">
      <h2 class="hb-logo-huge"><em>Chiba</em></h2>
      <h3 class="hb-title" data-i18n="hero.title">O escapadă montană autentică</h3>
      <p class="hb-desc" data-i18n="hero.desc">
        Combinând confortul modern cu peisajele pitorești,<br> Cabana Chiba este ideală pentru relaxare și drumeții.
      </p>
      <a href="#rooms" class="hb-btn" data-i18n="hero.btn">Descoperă cabana</a>
    </div>
  </div>
</section>

<style>
  .hero-video-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-vid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }
  .hb-actions {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hb-booking {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #F5F0E8;
    background: transparent;
    border: 1px solid rgba(245, 240, 232, 0.35);
    padding: 0.8rem 1.5rem;
    transition: all 0.4s ease;
    text-decoration: none;
  }
  .hb-booking:hover {
    background: rgba(245, 240, 232, 0.12);
    border-color: rgba(245, 240, 232, 0.6);
  }
</style>

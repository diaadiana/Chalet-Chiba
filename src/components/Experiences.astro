---
<section id="exp" class="exp-section">
  <div class="exp-container">

    <div class="exp-card">
      <div class="flip-inner">
        <div class="flip-front">
          <h3 class="exp-card-title" data-i18n="exp.card1_title">Trasee montane în apropiere</h3>
        </div>
        <div class="flip-back">
          <p class="exp-card-desc" data-i18n="exp.card1_desc">Suntem punctul ideal de plecare spre faimosul <a href="https://www.google.com/maps/search/?api=1&query=Canionul+Sapte+Scari" target="_blank" rel="noopener noreferrer">Canionul Șapte Scări</a> și <a href="https://www.google.com/maps/search/?api=1&query=Masivul+Piatra+Mare" target="_blank" rel="noopener noreferrer">Masivul Piatra Mare</a>. Tot în apropiere te poți bucura de spectaculoasa <a href="https://www.google.com/maps/search/?api=1&query=Cascada+Tamina" target="_blank" rel="noopener noreferrer">Cascadă Tamina</a>.</p>
        </div>
      </div>
    </div>

    <div class="exp-card">
      <div class="flip-inner">
        <div class="flip-front">
          <h3 class="exp-card-title" data-i18n="exp.card2_title">Activități pentru copii</h3>
        </div>
        <div class="flip-back">
          <p class="exp-card-desc" data-i18n="exp.card2_desc">La scurtă distanță de noi se află tirolienele de la <a href="https://www.google.com/maps/search/?api=1&query=Canionul+Sapte+Scari" target="_blank" rel="noopener noreferrer">Șapte Scări</a> și faimosul <a href="https://www.google.com/maps/search/?api=1&query=Parc+Aventura+Brasov" target="_blank" rel="noopener noreferrer">Parc Aventura</a>. Natura din jur oferă poteci ușoare, perfecte pentru micii exploratori.</p>
        </div>
      </div>
    </div>

    <div class="exp-card">
      <div class="flip-inner">
        <div class="flip-front">
          <h3 class="exp-card-title" data-i18n="exp.card3_title">Centrul Brașovului</h3>
        </div>
        <div class="flip-back">
          <p class="exp-card-desc" data-i18n="exp.card3_desc">La doar 10-15 minute (aprox. 10 km) cu mașina, te așteaptă <a href="https://www.google.com/maps/search/?api=1&query=Piata+Sfatului+Brasov" target="_blank" rel="noopener noreferrer">Piața Sfatului</a>, <a href="https://www.google.com/maps/search/?api=1&query=Biserica+Neagra+Brasov" target="_blank" rel="noopener noreferrer">Biserica Neagră</a> și farmecul inegalabil al cafenelelor din inima orașului.</p>
        </div>
      </div>
    </div>

  </div>
</section>

<style is:global>
  .exp-section {
    background: var(--forest, #1A3A1A);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 5%;
  }

  .exp-container {
    display: flex;
    gap: 3.5rem;
    width: 100%;
    max-width: 1280px;
    justify-content: center;
    align-items: center;
  }

  .exp-card {
    flex: 1;
    height: 390px;
    perspective: 1200px;
  }

  .flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.85s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 12px;
  }

  /* ONLY auto-flip via JS class — no hover */
  .exp-card.flipped .flip-inner {
    transform: rotateY(180deg);
  }

  .flip-front,
  .flip-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: var(--off, #F9F6F0);
    /* No box-shadow */
  }

  .flip-back {
    transform: rotateY(180deg);
    text-align: center;
  }

  .exp-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem;
    font-weight: 500;
    color: var(--forest, #1A3A1A);
    margin: 0;
    line-height: 1.4;
    border-top: 1px solid var(--forest, #1A3A1A);
    border-bottom: 1px solid var(--forest, #1A3A1A);
    padding: 1rem 0;
    display: inline-block;
    text-align: center;
  }

  .exp-card-desc {
    font-family: 'Jost', sans-serif;
    font-size: 1.05rem;
    line-height: 1.6;
    color: #4A5A43;
    margin: 0;
  }

  .exp-card-desc a {
    color: var(--gold, #B8955A);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px dotted var(--gold, #B8955A);
    transition: color 0.3s ease;
  }

  .exp-card-desc a:hover {
    color: var(--forest, #1A3A1A);
    border-bottom: 1px solid var(--forest, #1A3A1A);
  }

  @media (max-width: 900px) {
    .exp-container {
      flex-direction: column;
      gap: 2rem;
      padding: 2rem 0;
    }
    .exp-card {
      width: 100%;
      max-width: 400px;
      height: 280px;
      margin: 0 auto;
    }
  }
</style>

<script>
  const expSection = document.getElementById('exp');
  const cards = document.querySelectorAll('.exp-card');
  let flipTimer: ReturnType<typeof setTimeout> | null = null;
  let hasFlipped = false;

  function flipAll() {
    // All 3 flip simultaneously
    cards.forEach(card => card.classList.add('flipped'));
    hasFlipped = true;
  }

  function resetAll() {
    cards.forEach(card => card.classList.remove('flipped'));
    hasFlipped = false;
    if (flipTimer) { clearTimeout(flipTimer); flipTimer = null; }
  }

  const expObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        if (!hasFlipped) {
          flipTimer = setTimeout(flipAll, 2500); // 2.5s delay
        }
      } else {
        resetAll();
      }
    });
  }, { threshold: 0.5 });

  if (expSection) expObserver.observe(expSection);
</script>

---
<section id="exp" class="exp-section">
  <div class="exp-container">

    <div class="exp-card">
      <div class="flip-inner">
        <div class="flip-front">
          <h3 class="exp-card-title" data-i18n="exp.card1_title">Trasee montane în apropiere</h3>
        </div>
        <div class="flip-back">
          <p class="exp-card-desc" data-i18n="exp.card1_desc">Suntem punctul ideal de plecare spre faimosul <a href="https://www.google.com/maps/search/?api=1&query=Canionul+Sapte+Scari" target="_blank" rel="noopener noreferrer">Canionul Șapte Scări</a> și <a href="https://www.google.com/maps/search/?api=1&query=Masivul+Piatra+Mare" target="_blank" rel="noopener noreferrer">Masivul Piatra Mare</a>. Tot în apropiere te poți bucura de spectaculoasa <a href="https://www.google.com/maps/search/?api=1&query=Cascada+Tamina" target="_blank" rel="noopener noreferrer">Cascadă Tamina</a>.</p>
        </div>
      </div>
    </div>

    <div class="exp-card">
      <div class="flip-inner">
        <div class="flip-front">
          <h3 class="exp-card-title" data-i18n="exp.card2_title">Activități pentru copii</h3>
        </div>
        <div class="flip-back">
          <p class="exp-card-desc" data-i18n="exp.card2_desc">La scurtă distanță de noi se află tirolienele de la <a href="https://www.google.com/maps/search/?api=1&query=Canionul+Sapte+Scari" target="_blank" rel="noopener noreferrer">Șapte Scări</a> și faimosul <a href="https://www.google.com/maps/search/?api=1&query=Parc+Aventura+Brasov" target="_blank" rel="noopener noreferrer">Parc Aventura</a>. Natura din jur oferă poteci ușoare, perfecte pentru micii exploratori.</p>
        </div>
      </div>
    </div>

    <div class="exp-card">
      <div class="flip-inner">
        <div class="flip-front">
          <h3 class="exp-card-title" data-i18n="exp.card3_title">Centrul Brașovului</h3>
        </div>
        <div class="flip-back">
          <p class="exp-card-desc" data-i18n="exp.card3_desc">La doar 10-15 minute (aprox. 10 km) cu mașina, te așteaptă <a href="https://www.google.com/maps/search/?api=1&query=Piata+Sfatului+Brasov" target="_blank" rel="noopener noreferrer">Piața Sfatului</a>, <a href="https://www.google.com/maps/search/?api=1&query=Biserica+Neagra+Brasov" target="_blank" rel="noopener noreferrer">Biserica Neagră</a> și farmecul inegalabil al cafenelelor din inima orașului.</p>
        </div>
      </div>
    </div>

  </div>
</section>

<style is:global>
  .exp-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 5%;
  }

  .exp-container {
    display: flex;
    gap: 3.5rem;
    width: 100%;
    max-width: 1280px;
    justify-content: center;
    align-items: center;
  }

  .exp-card {
    flex: 1;
    height: 390px;
    perspective: 1200px;
  }

  .flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.85s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 12px;
  }

  /* ONLY auto-flip via JS class — no hover */
  .exp-card.flipped .flip-inner {
    transform: rotateY(180deg);
  }

  .flip-front,
  .flip-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: var(--off, #F9F6F0);
    /* No box-shadow */
  }

  .flip-back {
    transform: rotateY(180deg);
    text-align: center;
  }

  .exp-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem;
    font-weight: 500;
    color: var(--forest, #1A3A1A);
    margin: 0;
    line-height: 1.4;
    border-top: 1px solid var(--forest, #1A3A1A);
    border-bottom: 1px solid var(--forest, #1A3A1A);
    padding: 1rem 0;
    display: inline-block;
    text-align: center;
  }

  .exp-card-desc {
    font-family: 'Jost', sans-serif;
    font-size: 1.05rem;
    line-height: 1.6;
    color: #4A5A43;
    margin: 0;
  }

  .exp-card-desc a {
    color: var(--gold, #B8955A);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px dotted var(--gold, #B8955A);
    transition: color 0.3s ease;
  }

  .exp-card-desc a:hover {
    color: var(--forest, #1A3A1A);
    border-bottom: 1px solid var(--forest, #1A3A1A);
  }

  @media (max-width: 900px) {
    .exp-section {
      padding: 2rem 5%;
    }
    .exp-container {
      flex-direction: column;
      gap: 1.5rem;
      padding: 1rem 0;
    }
    .exp-card {
      width: 90%;
      max-width: 400px;
      height: 220px;
      margin: 0 auto;
    }
    .exp-card-title {
      font-size: 1.8rem;
    }
    .exp-card-desc {
      font-size: 0.95rem;
      line-height: 1.4;
    }
    .flip-front, .flip-back {
      padding: 1.2rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initExperiencesAnimation() {
    const expSection = document.getElementById('exp');
    const cards = gsap.utils.toArray('.exp-card');
    
    if (!expSection || cards.length === 0) return;

    // Resetam posibile transformari anterioare
    cards.forEach((card: any) => {
      gsap.set(card.querySelector('.flip-inner'), { clearProps: "all" });
    });

    // Timeline universal cu pin pentru ambele ecrane (Desktop/Mobile)
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: expSection,
        start: "top top",
        end: `+=${window.innerHeight * 1.5}`, // lungimea de scroll pe parcursul careia se intorc cardurile
        scrub: 1, // urmareste fin degetul/scroll-ul
        pin: true,
        snap: {
          snapTo: 1 / cards.length, // Snap exact pe fiecare card (33.3%)
          duration: { min: 0.2, max: 0.6 },
          ease: "power1.inOut"
        }
      }
    });

    // Animam fiecare card sa se intoarca pe rand
    cards.forEach((card: any) => {
      tl.to(card.querySelector('.flip-inner'), {
        rotateY: 180,
        duration: 1,
        ease: "none"
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initExperiencesAnimation);
  } else {
    initExperiencesAnimation();
  }
</script>

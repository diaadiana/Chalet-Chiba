---
const cards = [
  {
    title: 'Trasee montane în apropiere',
    description: 'Suntem punctul ideal de plecare spre faimosul <a href="https://www.google.com/maps/search/?api=1&query=Canionul+Sapte+Scari" target="_blank" rel="noopener noreferrer">Canionul Șapte Scări</a> și <a href="https://www.google.com/maps/search/?api=1&query=Masivul+Piatra+Mare" target="_blank" rel="noopener noreferrer">Masivul Piatra Mare</a>. Tot în apropiere te poți bucura de spectaculoasa <a href="https://www.google.com/maps/search/?api=1&query=Cascada+Tamina" target="_blank" rel="noopener noreferrer">Cascadă Tamina</a>.',
  },
  {
    title: 'Activități pentru copii',
    description: 'La scurtă distanță de noi se află tirolienele de la <a href="https://www.google.com/maps/search/?api=1&query=Canionul+Sapte+Scari" target="_blank" rel="noopener noreferrer">Șapte Scări</a> și faimosul <a href="https://www.google.com/maps/search/?api=1&query=Parc+Aventura+Brasov" target="_blank" rel="noopener noreferrer">Parc Aventura</a>. Natura din jur oferă poteci ușoare, perfecte pentru micii exploratori.',
  },
  {
    title: 'Centrul Brașovului',
    description: 'La doar 10-15 minute (aprox. 10 km) cu mașina, te așteaptă <a href="https://www.google.com/maps/search/?api=1&query=Piata+Sfatului+Brasov" target="_blank" rel="noopener noreferrer">Piața Sfatului</a>, <a href="https://www.google.com/maps/search/?api=1&query=Biserica+Neagra+Brasov" target="_blank" rel="noopener noreferrer">Biserica Neagră</a> și farmecul inegalabil al cafenelelor din inima orașului.',
  }
];
---
<section id="exp" class="exp-section">
  <div class="exp-container">
    {cards.map((card, index) => (
      <div class="exp-card">
        <div class="exp-card-content">
          <h3 class="exp-card-title">{card.title}</h3>
          <p class="exp-card-desc" set:html={card.description}></p>
        </div>
        <div class="exp-hint">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .exp-section {
    background: var(--forest, #1A3A1A); /* Fundal verde */
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 5%;
  }

  .exp-container {
    display: flex;
    gap: 3rem;
    width: 100%;
    max-width: 1200px;
    justify-content: center;
    align-items: center;
  }

  .exp-card {
    position: relative;
    flex: 1;
    display: grid;
    place-items: center; /* Centrează absolut pe verticală și orizontală */
    background: var(--off, #F9F6F0); /* Carduri crem */
    border-radius: 12px;
    box-shadow: 0 15px 30px rgba(0,0,0,0.4); /* Umbră mai închisă pe fundalul verde */
    height: 340px; /* Înălțime fixă redusă (mai mică inițial) */
    transition: height 0.4s ease, transform 0.4s ease, box-shadow 0.4s ease;
  }

  .exp-card:hover {
    height: 480px; /* Crește în lungime (pe verticală) */
    transform: translateY(-10px);
    box-shadow: 0 25px 40px rgba(0,0,0,0.25);
    z-index: 10;
  }

  .exp-card-content {
    padding: 2rem;
    text-align: center;
    width: 100%;
    transform: translateY(0);
    transition: transform 0.4s ease;
  }
  
  .exp-card:hover .exp-card-content {
    transform: translateY(0); /* Nu mai e nevoie să o mutăm pentru că se alungește cardul */
  }

  .exp-card-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem;
    font-weight: 500;
    color: var(--forest, #1A3A1A);
    margin: 0;
    line-height: 1.4;
    border-top: 1px solid var(--forest, #1A3A1A);
    border-bottom: 1px solid var(--forest, #1A3A1A);
    padding: 1rem 0;
    display: inline-block;
    transition: padding 0.4s ease;
  }

  .exp-card-desc {
    font-family: 'Jost', sans-serif;
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--muted, #4A5A43);
    margin: 0;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transform: translateY(20px);
    transition: all 0.4s ease;
  }

  .exp-card-desc :global(a) {
    color: var(--gold, #B8955A);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
    border-bottom: 1px dotted var(--gold, #B8955A);
  }

  .exp-card-desc :global(a:hover) {
    color: var(--forest, #1A3A1A);
    border-bottom: 1px solid var(--forest, #1A3A1A);
  }

  .exp-card:hover .exp-card-desc {
    opacity: 1;
    max-height: 300px; /* Limită mărită pentru a încăpea tot textul fără să fie tăiat */
    margin-top: 1.5rem;
    transform: translateY(0);
  }

  @keyframes bounceHint {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(5px); }
  }

  .exp-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--forest, #1A3A1A);
    opacity: 0.4;
    transition: opacity 0.3s ease;
    animation: bounceHint 2s infinite ease-in-out;
  }

  .exp-card:hover .exp-hint {
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .exp-container {
      flex-direction: column;
      gap: 2rem;
      padding: 2rem 0;
    }
    
    .exp-card {
      width: 100%;
      max-width: 400px;
      height: 280px; /* Mai scurt pe mobil inițial */
      margin: 0 auto;
    }

    .exp-card:hover {
      height: 420px; /* Crește în lungime și pe mobil */
    }
  }
</style>

---
import rawSvg from '../../public/preloadercabana.svg?raw';
---

<div id="preloader">
  <div class="preloader-content">
    <div id="preloader-icon">
      <Fragment set:html={rawSvg} />
    </div>
    <div id="preloader-text">
      Chalet <em>Chiba</em>
    </div>
  </div>
</div>

<style>
  #preloader {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Glassmorphism Implementation */
    background: rgba(10, 14, 10, 0.35); /* Dark subtle tint */
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    transition: opacity 1.4s cubic-bezier(0.7, 0, 0.3, 1),
                visibility 1.4s;
  }

  #preloader.loaded {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .preloader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    gap: 2rem;
  }

  #preloader-icon {
    width: 180px;
    max-width: 50vw;
    color: #fff; /* Crisp white for max contrast */
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.4)); /* Elegant glow/shadow */
    clip-path: inset(100% 0% 0% 0%); /* Initially hidden from top */
  }

  #preloader-icon :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }

  #preloader-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    color: #fff;
    letter-spacing: 0.03em;
    font-weight: 400;
    text-shadow: 0 4px 16px rgba(0, 0, 0, 0.5); /* Matching shadow */
    opacity: 0; /* Hidden initially for fade-in */
  }

  #preloader-text em {
    font-style: italic;
    letter-spacing: -0.01em;
  }
</style>

<script>
  import gsap from 'gsap';

  function initPreloader() {
    const preloader = document.getElementById('preloader');
    const icon = document.getElementById('preloader-icon');
    const text = document.getElementById('preloader-text');
    
    if (!icon || !text) {
      setTimeout(() => preloader?.classList.add('loaded'), 1000);
      return;
    }

    const tl = gsap.timeline({
      onComplete: () => {
        // Dispare după animație
        setTimeout(() => preloader?.classList.add('loaded'), 600);
      }
    });

    // Animația cabanei ("se construiește" de jos în sus în 2 secunde)
    tl.to(icon, {
      clipPath: 'inset(0% 0% 0% 0%)',
      duration: 2,
      ease: 'power2.inOut'
    }, 0);

    // Textul apare treptat
    tl.to(text, {
      opacity: 1,
      duration: 1.5,
      ease: 'power2.out'
    }, 0.5); // Începe cu o mică întârziere (după jumătate de secundă)
    
    // Fallback de siguranță
    setTimeout(() => preloader?.classList.add('loaded'), 5000);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPreloader);
  } else {
    initPreloader();
  }
</script>

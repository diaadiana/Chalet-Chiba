---
import rawSvg from '../../public/preloadercabana.svg?raw';
---

<div id="preloader">
  <div class="preloader-content">
    <div id="preloader-icon">
      <Fragment set:html={rawSvg} />
    </div>
    <div id="preloader-text">
      Chalet <em>Chiba</em>
    </div>
  </div>
</div>

<style>
  #preloader {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(20, 30, 20, 0.2); /* Perfect neutral mix-blend glassmorphism */
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    will-change: opacity;
    transform: translate3d(0, 0, 0);
    transition: opacity 1.4s cubic-bezier(0.7, 0, 0.3, 1),
                visibility 1.4s;
  }

  #preloader.loaded {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .preloader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    gap: 2rem;
  }

  #preloader-icon {
    width: 180px;
    max-width: 50vw;
    color: #fff; /* White for perfect contrast against the blurred landscape */
    clip-path: inset(100% 0% 0% 0%);
    transition: filter 0.5s ease;
  }

  /* Soft shadow for depth and legibility */
  #preloader-icon.has-shadow {
    filter: drop-shadow(0 6px 16px rgba(0, 0, 0, 0.3));
  }

  #preloader-icon :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }

  #preloader-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    color: #fff;
    letter-spacing: 0.03em;
    font-weight: 400;
    text-shadow: 0 4px 12px rgba(0, 0, 0, 0.4);
    opacity: 0;
  }

  #preloader-text em {
    font-style: italic;
    letter-spacing: -0.01em;
  }
</style>

<script>
  import gsap from 'gsap';

  function initPreloader() {
    const preloader = document.getElementById('preloader');
    const icon = document.getElementById('preloader-icon');
    const text = document.getElementById('preloader-text');
    
    // Get the video element on the landing page
    const video = document.querySelector('.hero-vid') as HTMLVideoElement | null;
    
    let isVideoReady = false;
    let isAnimDone = false;
    let fallbackTimeout: any = null;

    function hidePreloader() {
      if (!preloader || preloader.classList.contains('loaded')) return;
      
      clearTimeout(fallbackTimeout);
      preloader.classList.add('loaded');
      
      // Ensure the background video starts playing seamlessly
      if (video) {
        video.play().catch(e => {
          console.log('Video autoplay blocked or interrupted:', e);
        });
      }
    }

    function checkReady() {
      // Hide the preloader only when the animation is finished AND the video is ready to play
      if (isAnimDone && (isVideoReady || !video)) {
        hidePreloader();
      }
    }

    // Safety fallback: if video or assets take too long to load, hide preloader anyway after 4 seconds
    fallbackTimeout = setTimeout(() => {
      hidePreloader();
    }, 4000);

    if (video) {
      if (video.readyState >= 3) {
        isVideoReady = true;
      } else {
        video.addEventListener('canplay', () => {
          isVideoReady = true;
          checkReady();
        }, { once: true });
        video.addEventListener('loadeddata', () => {
          isVideoReady = true;
          checkReady();
        }, { once: true });
      }
    }

    if (!icon || !text) {
      setTimeout(hidePreloader, 1000);
      return;
    }

    const tl = gsap.timeline({
      onComplete: () => {
        // Apply the drop-shadow filter only when animation is done
        icon.classList.add('has-shadow');
        isAnimDone = true;
        checkReady();
      }
    });

    // Cabin building animation (reveal from bottom-up in 2.2 seconds)
    tl.to(icon, {
      clipPath: 'inset(0% 0% 0% 0%)',
      duration: 2.2,
      ease: 'power2.inOut'
    }, 0);

    // Text fades in smoothly
    tl.to(text, {
      opacity: 1,
      duration: 1.6,
      ease: 'power2.out'
    }, 0.6);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPreloader);
  } else {
    initPreloader();
  }
</script>

---
---

<div id="preloader">
  <div class="preloader-content">
    <div id="preloader-title">
      <!-- Letters will be injected here via JS -->
    </div>
    <div id="preloader-sub" data-i18n="preloader.sub">
      O escapadă montană
    </div>
  </div>
</div>

<style>
  #preloader {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at center, #2D4A3E 0%, #1A2E26 100%);
    transition: opacity 1.2s cubic-bezier(0.7, 0, 0.3, 1), 
                filter 1.2s cubic-bezier(0.7, 0, 0.3, 1),
                visibility 1.2s;
  }
  
  #preloader.loaded {
    opacity: 0;
    filter: blur(40px);
    visibility: hidden;
    pointer-events: none;
  }

  .preloader-content {
    position: relative;
    z-index: 10;
    text-align: center;
  }

  #preloader-title {
    display: flex;
    gap: 0.1em;
    justify-content: center;
    align-items: center;
  }

  /* Keyframe for blur reveal */
  @keyframes blurIn {
    0% {
      filter: blur(20px);
      opacity: 0;
      transform: scale(1.4);
    }
    100% {
      filter: blur(0px);
      opacity: 1;
      transform: scale(1);
    }
  }

  :global(.letter) {
    display: inline-block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.5rem;
    font-weight: 300;
    color: #F5F0E8;
    opacity: 0;
    filter: blur(20px);
  }

  @media (min-width: 768px) {
    :global(.letter) { font-size: 5.5rem; }
  }

  :global(.letter.animate) {
    animation: blurIn 1.2s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  #preloader-sub {
    margin-top: 24px;
    color: #B8955A; /* Using the gold color variable */
    font-size: 0.7rem;
    letter-spacing: 0.6em;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity 1s 1.5s;
  }

  #preloader-sub.animate {
    opacity: 0.5;
  }
</style>

<script>
  function initPreloader() {
    const preloader = document.getElementById('preloader');
    const titleContainer = document.getElementById('preloader-title');
    const subText = document.getElementById('preloader-sub');
    const text = "CHALET CHIBA";
    
    if (!titleContainer) return;

    // Create spans for each letter
    text.split('').forEach((char, i) => {
      const span = document.createElement('span');
      span.textContent = char === ' ' ? '\u00A0' : char;
      span.className = 'letter';
      span.style.animationDelay = `${i * 0.08}s`;
      titleContainer.appendChild(span);
    });

    // Animate in
    setTimeout(() => {
      const letters = document.querySelectorAll('.letter');
      letters.forEach(l => l.classList.add('animate'));
      subText?.classList.add('animate');
    }, 200);

    // Transition out
    setTimeout(() => {
      preloader?.classList.add('loaded');
      // Eliminăm complet logica de overflow: hidden care interacționa negativ cu GSAP
    }, 4000);
  }

  if (document.readyState === 'complete') {
    initPreloader();
  } else {
    window.addEventListener('load', initPreloader);
  }
  // Am scos document.body.style.overflow = 'hidden'; 
  // Preloaderul acoperă ecranul, deci background scroll-ul nu va deranja vizual, 
  // dar permite GSAP-ului să calculeze corect înălțimile încă de la început.
</script>

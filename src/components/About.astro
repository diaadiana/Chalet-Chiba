---
---
<section id="about" class="about-section">

  <div class="layout-container">
    <div class="large-rect" id="about-large-rect">
      <div class="about-inner">
        <p class="about-text" id="about-text" data-i18n="about.text1">
          Încetinește. Alege liniștea pădurii, ascultă pârâul din curte și redescoperă o dimineață fără agendă. Un adăpost liniștit lângă Brașov.
        </p>
      </div>
      <!-- Floating Bird in the bottom left of the green box -->
      <div class="about-bird-container-new">
        <img src="/images/pasere1.svg?v=3" alt="Pasăre decorativă" class="about-bird-img" />
      </div>
    </div>

    <div class="small-rect">
      <img src="/images/Chiba-23.webp" alt="Pârâul din curte" class="attached-image" id="water-image" />
    </div>
  </div>
</section>

<style>
  .about-section {
    background: #E3EAE0; /* faded/muted greenish background */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 5%;
    position: relative;
    overflow: hidden;
  }

  .layout-container {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    width: 100%;
    max-width: 1100px; /* Am micșorat lățimea maximă pentru a face ambele dreptunghiuri mai mici */
    align-items: center;
    position: relative;
    margin: 0 auto;
  }

  .large-rect {
    grid-column: 2 / 10; /* Restored column space for text room */
    grid-row: 1;
    background-color: var(--forest, #1A3A1A);
    position: relative;
    padding: 4rem 10rem 4rem 4rem; /* Substantial right padding to block text from overlapping with the small image */
    min-height: 48vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }

  .small-rect {
    grid-column: 9 / 12; /* Overlaps with large-rect (spans 2/10) to visually connect the elements */
    grid-row: 1;
    z-index: 5;
    aspect-ratio: 1.15 / 1;
    max-width: 275px; /* increased slightly from 240px to 275px */
    box-shadow: 0 15px 30px rgba(0,0,0,0.2);
  }

  .attached-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }


  .about-inner {
    position: relative;
    z-index: 2; /* textul deasupra ramurilor */
    max-width: 900px;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .about-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 2.5vw, 2.4rem);
    line-height: 1.65;
    font-weight: 500;
    font-style: italic; /* Text cursiv */
    margin: 0;
    max-width: 60ch;
    text-wrap: balance;
    text-align: center;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    color: var(--off, #F9F6F0); /* Text is now cream to contrast with green background */
  }

  :global(.about-text .word) {
    opacity: 0.25;
    display: inline-block;
    will-change: opacity;
  }

  .about-facilities-tags {
    margin-top: 0.5rem;
  }

  .facility-tag {
    font-family: 'Jost', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.7);
    font-weight: 400;
    transition: color 0.3s ease, transform 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    cursor: default;
  }

  .facility-tag:hover {
    color: var(--gold);
    transform: translateY(-1px);
  }

  .tag-bullet {
    color: var(--gold);
    font-size: 0.9rem;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  @media (max-width: 992px) {
    .about-section {
      padding: 5rem 1.5rem 6.5rem 1.5rem; /* extra bottom padding to accommodate the overlapping image */
    }
    .layout-container {
      display: flex;
      flex-direction: column;
      width: 100%;
      max-width: 500px; /* bounds width on mobile/tablets to keep it elegant and readable */
      margin: 0 auto;
      position: relative;
    }
    .large-rect {
      width: 100%;
      padding: 4.5rem 2.2rem 5.5rem 2.2rem; /* extra bottom padding so text doesn't touch the overlapping image bounds */
      min-height: auto;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }
    .small-rect {
      width: 75%;
      max-width: 300px;
      aspect-ratio: 1.15 / 1;
      margin-top: -3.8rem; /* vertical overlap */
      align-self: flex-end; /* aligned to the right */
      margin-right: 1rem; /* slight offset from the right boundary for a more dynamic, artistic look */
      z-index: 5;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.18);
      border-radius: 4px;
    }
    .about-text {
      font-size: clamp(1.2rem, 4.5vw, 1.55rem);
      line-height: 1.6;
    }
  }

  /* Floating Chirping Bird */
  .about-bird-container-new {
    position: absolute;
    bottom: 1rem;
    left: 1.5rem;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    user-select: none;
    -webkit-user-drag: none;
    width: 4.5rem;
    height: auto;
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.55), z-index 0.6s step-end;
    transform-origin: left bottom;
  }

  .about-bird-container-new.zoomed {
    z-index: 99;
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.55), z-index 0s;
    transform: scale(4.2) translateY(-8px) translateX(8px) rotate(6deg); /* BOOM zoom slightly adjusted for larger base size */
  }

  .about-bird-container-new:hover:not(.zoomed) {
    transform: scale(1.15) rotate(-4deg);
  }

  .about-bird-img {
    width: 100%;
    height: auto;
    opacity: 0.85;
    display: block;
    transition: opacity 0.3s ease;
  }

  .about-bird-container-new:hover .about-bird-img,
  .about-bird-container-new.zoomed .about-bird-img {
    opacity: 1;
  }



  /* Responsive layout overrides */
  @media (max-width: 900px) {
    .about-bird-container-new {
      bottom: 0.8rem;
      left: 0.7rem;
      width: 3.5rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import SplitType from "split-type";

  gsap.registerPlugin(ScrollTrigger);

  function initAbout() {
    const section  = document.getElementById("about");
    const largeRect = document.getElementById("about-large-rect");
    const textEl   = document.getElementById("about-text") as HTMLElement | null;

    if (!section || !largeRect || !textEl) return;

    // Click to Zoom Interactive easter-egg
    const bird = section.querySelector('.about-bird-container-new');
    if (bird) {
      bird.addEventListener('click', () => {
        bird.classList.toggle('zoomed');
      });
    }

    let split: InstanceType<typeof SplitType> | null = null;
    let st: ScrollTrigger | null = null;
    let lastWidth = window.innerWidth;

    function build() {
      if (st)    { st.kill();      st    = null; }
      if (split) { split.revert(); split = null; }

      // Fetch the translated string from translationsCache and assign it back to the node before split-type runs
      const currentLang = localStorage.getItem('lang') || 'ro';
      const key = textEl.getAttribute('data-i18n');
      if (key && (window as any).translationsCache && (window as any).translationsCache[currentLang] && (window as any).translationsCache[currentLang][key]) {
        textEl.innerHTML = (window as any).translationsCache[currentLang][key];
      }

      // ── Split text into words ───────────────────────────────────────
      split = new SplitType(textEl, { types: "words", tagName: "span" });
      const words = split.words as HTMLElement[];
      gsap.set(words, { opacity: 0.25 });

      // ── Master timeline — pinned + scrubbed cu gap mai mic ────────────────
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "center center",
          end: () => `+=${window.innerHeight * 0.5}`, /* Gap redus semnificativ */
          pin: true,
          scrub: 1.2,
          invalidateOnRefresh: true,
        },
      });

      // Cuvintele apar treptat
      tl.to(words, {
        opacity: 1,
        ease: "power2.out",
        duration: 0.8,
        stagger: { each: 0.35 },
      }, 0);

      st = tl.scrollTrigger as ScrollTrigger;
    }

    // Delay slightly to ensure translationsCache is initialized by Layout.astro
    document.fonts.ready.then(() => setTimeout(build, 100));

    window.addEventListener("resize", () => {
      if (window.innerWidth === lastWidth) return;
      lastWidth = window.innerWidth;
      build();
    }, { passive: true });

    window.addEventListener("langChanged", (e: any) => {
      const currentLang = e.detail || localStorage.getItem('lang') || 'ro';
      // Fetch text directly from local storage key to update textEl before rebuilding split
      const key = textEl.getAttribute('data-i18n');
      if (key && (window as any).translationsCache && (window as any).translationsCache[currentLang] && (window as any).translationsCache[currentLang][key]) {
        textEl.innerHTML = (window as any).translationsCache[currentLang][key];
      }
      setTimeout(build, 80);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAbout);
  } else {
    initAbout();
  }
</script>

---
---
<nav id="mainNav">
  <div class="logo" id="mobile-pill-btn" role="button" tabindex="0" aria-expanded="false" aria-label="Meniu Navigare">
    <div class="logo-n">
      Chalet <em>Chiba</em>
      <svg class="pill-arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="m6 9 6 6 6-6"/>
      </svg>
    </div>
  </div>
  <div class="nav-links">
    <a href="#about" data-i18n="nav.about">Despre</a>
    <a href="#rooms" data-i18n="nav.rooms">Camere</a>
    <a href="#exp" data-i18n="nav.exp">Experiențe</a>
    <a href="#gallery" data-i18n="nav.gallery">Galerie</a>
    <a href="#rezerva" data-i18n="nav.rezerva">Rezervări</a>
    <a href="#contact" data-i18n="nav.contact">Contact</a>
  </div>
</nav>

<!-- Mobile Menu Drawer Modal -->
<div id="mobile-menu-drawer" class="mobile-menu-drawer">
  <div class="mobile-menu-backdrop" id="mobile-menu-backdrop"></div>
  <div class="mobile-menu-panel">
    <div class="mobile-menu-top">
      <div class="mobile-menu-brand">Chalet <em>Chiba</em></div>
      <button id="mobile-menu-close-btn" class="mobile-menu-close-btn" aria-label="Închide meniul">&times;</button>
    </div>
    <div class="mobile-menu-nav-links">
      <a href="#about" data-i18n="nav.about">Despre</a>
      <a href="#rooms" data-i18n="nav.rooms">Camere</a>
      <a href="#exp" data-i18n="nav.exp">Experiențe</a>
      <a href="#gallery" data-i18n="nav.gallery">Galerie</a>
      <a href="#rezerva" data-i18n="nav.rezerva">Rezervări</a>
      <a href="#contact" data-i18n="nav.contact">Contact</a>
    </div>
  </div>
</div>

<!-- Top-right fixed corner: map pin + language switcher -->
<div class="nav-corner-r">
  <a href="https://maps.google.com/?q=Chalet+Chiba" target="_blank" rel="noopener noreferrer" class="nav-map-btn" title="Locație Google Maps">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="map-icon">
      <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
    </svg>
  </a>
  <div class="nav-lang">
    <button class="lang-btn" data-lang="ro">RO</button>
    <span class="lang-separator">|</span>
    <button class="lang-btn" data-lang="en">EN</button>
    <span class="lang-separator">|</span>
    <button class="lang-btn" data-lang="de">DE</button>
  </div>
</div>

<!-- Floating Audio Button (Independent of Nav scroll hiding) -->
<button id="nav-audio-btn" class="nav-audio-btn" title="Ascultă sunetul pădurii" aria-label="Sunetul pădurii">
  <svg class="bird-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <!-- Body Outline -->
    <path d="M 9.5 3.5 C 12.5 3.5 15.5 4.5 16.8 6.8 C 17.2 7.8 17 9.2 16 10.5 C 14.8 12.2 13.2 13.5 12 14.2 L 12 21 C 12 21.5 11.7 22 11.2 22 L 9.2 22 C 8.7 22 8.5 21.5 8.5 21 L 8.5 16 C 6 14.5 5.2 11.8 5.2 9.5 C 5.2 6.2 7.2 3.5 9.5 3.5 Z" />
    <!-- Beak -->
    <path d="M 16.8 6.8 L 19.5 7.3 L 16.6 8.3 Z" fill="currentColor" stroke="none" />
    <!-- Eye (white/cream fill with dark pupil) -->
    <circle cx="13.8" cy="7.2" r="2" stroke="currentColor" stroke-width="1.1" fill="var(--off, #F5F0E8)" />
    <circle cx="14.3" cy="7.2" r="0.8" fill="#1A341A" stroke="none" />
    <!-- Wing -->
    <path d="M 9.5 8.5 C 12.2 8.5 14 9.5 14.3 11 C 14.3 11.8 13.7 12.5 13 12.8 C 11.8 13.6 10.5 14 9.2 13.5 C 8.5 12.8 8.2 11.2 9.5 8.5 Z" />
    <!-- Wing Inner feathers -->
    <path d="M 12.5 9.8 C 13.2 10.3 13.5 11 13.3 11.8" />
    <path d="M 11.2 10.8 C 11.8 11.3 12.1 12 11.9 12.7" />
    <!-- Chest ticks (hand-drawn feather details) -->
    <path d="M 7.2 9 C 7 9.5 7 10 7.2 10.5" />
    <path d="M 6.3 10 C 6.1 10.5 6.1 11 6.3 11.5" />
    <path d="M 7.4 11.2 C 7.2 11.7 7.2 12.2 7.4 12.7" />
    <!-- Tail dividers -->
    <path d="M 9.7 16.5 L 9.7 21.5" />
    <path d="M 10.8 16.5 L 10.8 21.5" />
  </svg>
</button>

<style>
  .pill-arrow-icon {
    display: none;
    width: 14px;
    height: 14px;
    margin-left: 6px;
    vertical-align: middle;
    transition: transform 0.3s ease;
    color: var(--gold, #B8955A);
  }

  @media (max-width: 900px) {
    .logo {
      cursor: pointer;
      user-select: none;
      display: inline-flex;
      align-items: center;
    }
    .pill-arrow-icon {
      display: inline-block;
    }
    .logo.menu-open .pill-arrow-icon {
      transform: rotate(180deg);
    }
  }

  /* Mobile Overlay Drawer */
  .mobile-menu-drawer {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu-drawer.is-active {
    pointer-events: auto;
    opacity: 1;
  }

  .mobile-menu-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 24, 10, 0.75);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .mobile-menu-panel {
    position: absolute;
    top: 1.2rem;
    left: 1.2rem;
    right: 1.2rem;
    background: linear-gradient(165deg, rgba(28, 56, 28, 0.96) 0%, rgba(15, 34, 15, 0.98) 100%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 20px;
    padding: 1.8rem 1.6rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    transform: translateY(-20px) scale(0.96);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu-drawer.is-active .mobile-menu-panel {
    transform: translateY(0) scale(1);
  }

  .mobile-menu-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 1.2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 1.2rem;
  }

  .mobile-menu-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    color: #FAFAFA;
  }
  .mobile-menu-brand em {
    font-style: italic;
    color: var(--gold, #B8955A);
  }

  .mobile-menu-close-btn {
    background: rgba(255, 255, 255, 0.1);
    border: none;
    color: #FAFAFA;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    font-size: 1.5rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .mobile-menu-nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .mobile-menu-nav-links a {
    font-family: 'Jost', sans-serif;
    font-size: 1.15rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    padding: 0.7rem 0.5rem;
    border-radius: 8px;
    transition: background 0.2s, color 0.2s, padding-left 0.2s;
  }

  .mobile-menu-nav-links a:active,
  .mobile-menu-nav-links a:hover {
    background: rgba(255, 255, 255, 0.08);
    color: var(--gold, #B8955A);
    padding-left: 0.8rem;
  }
</style>

<script>
  const nav = document.getElementById('mainNav');
  if (nav) {
    const navCorner = document.querySelector('.nav-corner-r') as HTMLElement | null;

    function showNav() {
      nav.classList.remove('nav-hidden');
      if (navCorner) { navCorner.style.opacity = '1'; navCorner.style.pointerEvents = 'auto'; }
    }

    function hideNav() {
      nav.classList.add('nav-hidden');
      if (navCorner) { navCorner.style.opacity = '0'; navCorner.style.pointerEvents = 'none'; }
    }

    // Navbar visible ONLY when hero (#hero) is in view
    const heroSection = document.getElementById('hero');
    const heroObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          showNav();
        } else {
          hideNav();
        }
      });
    }, { threshold: 0.1 });

    if (heroSection) heroObserver.observe(heroSection);
  }

  // Mobile Pill Menu Toggle
  const pillBtn = document.getElementById('mobile-pill-btn');
  const mobileDrawer = document.getElementById('mobile-menu-drawer');
  const backdrop = document.getElementById('mobile-menu-backdrop');
  const closeBtn = document.getElementById('mobile-menu-close-btn');

  function openMobileMenu() {
    if (window.innerWidth <= 900) {
      mobileDrawer?.classList.add('is-active');
      pillBtn?.classList.add('menu-open');
      pillBtn?.setAttribute('aria-expanded', 'true');
    }
  }

  function closeMobileMenu() {
    mobileDrawer?.classList.remove('is-active');
    pillBtn?.classList.remove('menu-open');
    pillBtn?.setAttribute('aria-expanded', 'false');
  }

  pillBtn?.addEventListener('click', (e) => {
    if (window.innerWidth <= 900) {
      e.preventDefault();
      if (mobileDrawer?.classList.contains('is-active')) {
        closeMobileMenu();
      } else {
        openMobileMenu();
      }
    }
  });

  backdrop?.addEventListener('click', closeMobileMenu);
  closeBtn?.addEventListener('click', closeMobileMenu);

  // Close menu when clicking any nav link inside drawer
  mobileDrawer?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      closeMobileMenu();
    });
  });

  // Ambient Audio Logic
  const audioBtn = document.getElementById('nav-audio-btn');
  const audio = new Audio('/forest-ambient.mp3');
  audio.loop = true;
  audio.volume = 0;
  let isPlaying = false;
  let fadeInterval: any = null;

  function playAudio() {
    clearInterval(fadeInterval);
    audio.play().then(() => {
      audioBtn?.classList.add('playing');
      isPlaying = true;
      fadeInterval = setInterval(() => {
        if (audio.volume < 0.22) { // 22% is a perfect gentle ambient background volume
          audio.volume = Math.min(0.22, audio.volume + 0.02);
        } else {
          clearInterval(fadeInterval);
        }
      }, 80);
    }).catch(e => {
      console.log('Audio autoplay blocked:', e);
      audioBtn?.classList.remove('playing');
      isPlaying = false;
    });
  }

  function pauseAudio() {
    clearInterval(fadeInterval);
    fadeInterval = setInterval(() => {
      if (audio.volume > 0.02) {
        audio.volume = Math.max(0, audio.volume - 0.02);
      } else {
        clearInterval(fadeInterval);
        audio.pause();
        audioBtn?.classList.remove('playing');
        isPlaying = false;
      }
    }, 50);
  }

  if (audioBtn) {
    audioBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (isPlaying) {
        pauseAudio();
        localStorage.setItem('audioPreferred', 'false');
      } else {
        playAudio();
        localStorage.setItem('audioPreferred', 'true');
      }
    });
  }

  // If user preferred audio on a previous page load, play it on first interaction
  if (localStorage.getItem('audioPreferred') === 'true') {
    const startOnInteraction = () => {
      playAudio();
      document.removeEventListener('click', startOnInteraction);
    };
    document.addEventListener('click', startOnInteraction);
  }
</script>

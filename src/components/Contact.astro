---
<section id="contact" class="contact-section">
  
  <div class="contact-container">
    <div class="contact-grid">
      <div class="contact-info">
        <p class="contact-address" data-i18n="contact.address">
          <a href="https://www.google.com/maps/search/?api=1&query=Chalet+Chiba+Timisu+de+Jos" target="_blank" rel="noopener noreferrer">
            Strada Canionului, Timișu de Jos, Brașov
          </a>
        </p>
        <p class="contact-phone" data-i18n="contact.phone">
          <a href="tel:+40769555558">Telefon: +40 769 555 558</a>
        </p>
        <p class="contact-email" data-i18n="contact.email">
          <a href="mailto:contact@chaletchiba.ro">Email: contact@chaletchiba.ro</a>
        </p>
        <div class="contact-maps-links">
          <a href="https://www.google.com/maps/search/?api=1&query=Chalet+Chiba+Timisu+de+Jos" target="_blank" rel="noopener noreferrer" class="contact-map-btn">Google Maps</a>
          <a href="https://waze.com/ul?q=Chalet%20Chiba" target="_blank" rel="noopener noreferrer" class="contact-map-btn">Waze</a>
        </div>
      </div>
      
      <!-- Form Column -->
      <form class="contact-form" onsubmit="event.preventDefault(); const msg = this.querySelector('textarea').value; window.open('https://wa.me/40769555558?text=' + encodeURIComponent(msg), '_blank');">
        <h3 class="contact-form-title" data-i18n="contact.feedback_title">Trimite-ne un gând</h3>
        <textarea class="contact-textarea" placeholder="Mesajul tău..." data-i18n-placeholder="contact.feedback_placeholder" required></textarea>
        <button type="submit" class="contact-form-btn" data-i18n="contact.feedback_btn">Trimite pe WhatsApp</button>
      </form>
    </div>
  </div>

  <div class="contact-giant-text">Chalet <em>Chiba</em></div>

  <!-- Footer integrat -->
  <div class="contact-footer">
    <p class="contact-copy">&copy; 2026 Chalet Chiba</p>
    <p class="contact-credit">Designed and made by <a href="https://achieve.ro" target="_blank" rel="noopener noreferrer">achieve.ro</a></p>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  function initGiantText() {
    const el = document.querySelector('.contact-giant-text');
    if (!el) return;

    // Prevent duplicate wrapping
    if (el.querySelector('.jump-letter')) return;

    // Recursive text node wrapping to preserve formatting tags like <em>
    function wrapText(node: Node) {
      const children = Array.from(node.childNodes);
      children.forEach(child => {
        if (child.nodeType === Node.TEXT_NODE) {
          const text = child.textContent || '';
          const fragment = document.createDocumentFragment();
          text.split('').forEach(char => {
            if (char === ' ') {
              fragment.appendChild(document.createTextNode(' '));
            } else {
              const span = document.createElement('span');
              span.className = 'jump-letter';
              span.textContent = char;
              fragment.appendChild(span);
            }
          });
          child.parentNode?.replaceChild(fragment, child);
        } else if (child.nodeType === Node.ELEMENT_NODE) {
          wrapText(child);
        }
      });
    }

    wrapText(el);

    const letters = el.querySelectorAll('.jump-letter');
    if (letters.length === 0) return;

    // 1. Hover interaction
    letters.forEach(letter => {
      letter.addEventListener('mouseenter', () => {
        gsap.to(letter, {
          top: -22,
          duration: 0.16,
          ease: "power2.out",
          overwrite: "auto",
          onComplete: () => {
            gsap.to(letter, {
              top: 0,
              duration: 0.55,
              ease: "bounce.out"
            });
          }
        });
      });
    });

    // 2. Continuous random ambient jumps
    function scheduleJump() {
      const randIndex = Math.floor(Math.random() * letters.length);
      const letter = letters[randIndex];
      if (letter) {
        gsap.to(letter, {
          top: -15,
          duration: 0.2,
          ease: "power2.out",
          onComplete: () => {
            gsap.to(letter, {
              top: 0,
              duration: 0.55,
              ease: "bounce.out"
            });
          }
        });
      }
      setTimeout(scheduleJump, gsap.utils.random(800, 2500));
    }

    setTimeout(scheduleJump, 2000);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initGiantText);
  } else {
    initGiantText();
  }
</script>

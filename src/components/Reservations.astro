---
---
<section id="rezerva" class="rezerva-section">
  <div class="rezerva-header">
    <h2 class="rezerva-title" data-i18n="rezerva.title">Alege pachetul potrivit pentru escapada ta</h2>
  </div>
  
  <div class="rezerva-container">
    <div class="rezerva-cards">
      <!-- Midweek -->
      <div class="rezerva-card">
        <h3 class="rezerva-card-title" data-i18n="rezerva.midweek_title">Pachet Midweek</h3>
        <p class="rezerva-card-desc" data-i18n="rezerva.midweek_desc">Luni — Joi • Închiriere integrală</p>
        <span class="rezerva-card-price" data-i18n="rezerva.midweek_price">2.500 RON / Noapte</span>
      </div>
      
      <!-- Weekend -->
      <div class="rezerva-card special-card">
        <h3 class="rezerva-card-title" data-i18n="rezerva.weekend_title">Pachet Weekend</h3>
        <p class="rezerva-card-desc" data-i18n="rezerva.weekend_desc">Vineri — Duminică • Închiriere integrală</p>
        <span class="rezerva-card-price" data-i18n="rezerva.weekend_price">3.500 RON / Noapte</span>
      </div>
    </div>
    
    <!-- Minimalist details for Check-in / reception -->
    <div class="rezerva-info-meta">
      <div class="meta-item">
        <h4 class="meta-title" data-i18n="rezerva.check_in_title">Check-in & Check-out</h4>
        <p class="meta-desc" data-i18n="rezerva.check_in_desc">Check-in: după ora 14:00 • Check-out: înainte de ora 11:00.</p>
      </div>
      <div class="meta-item">
        <h4 class="meta-title" data-i18n="rezerva.reception_title">Rezervări Individuale</h4>
        <p class="meta-desc" data-i18n="rezerva.reception_desc">Contactează recepția cabanei pentru prețuri și disponibilitate pe camere individuale.</p>
      </div>
    </div>

    <div class="rezerva-action" style="text-align: center; margin-top: 3.5rem; display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap;">
      <a href="tel:+40769555558" class="rezerva-glass-btn" data-i18n="rezerva.btn">Sună pentru Rezervare</a>
      <a href="https://booking.com" target="_blank" class="rezerva-glass-btn">Rezervă prin Booking</a>
    </div>
  </div>
</section>

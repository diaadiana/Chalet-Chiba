<section id="rezerva" class="rezerva-section">

  <!-- Floating Golden Particles -->
  <div class="rezerva-particles" id="rezerva-particles"></div>

  <div class="rezerva-container">
    <div class="rezerva-single-card slide-up" style="transition-delay: 0.15s;">
      
      <!-- Pill Toggle -->
      <div class="pill-toggle-container slide-up" style="transition-delay: 0.3s;">
        <div class="pill-active-bg" id="pill-bg"></div>
        <button class="pill-btn active" id="btn-midweek" data-target="midweek" data-i18n="rezerva.midweek_btn">Midweek</button>
        <button class="pill-btn" id="btn-weekend" data-target="weekend" data-i18n="rezerva.weekend_btn">Weekend</button>
      </div>

      <!-- Content Area -->
      <div class="pricing-content-wrapper slide-up" style="transition-delay: 0.45s;">
        
        <!-- Midweek Content -->
        <div class="pricing-content active" id="content-midweek">
          <p class="pricing-days" data-i18n="rezerva.midweek_desc">Luni — Joi</p>
          <p class="pricing-price"><span class="shimmer-text" data-i18n="rezerva.midweek_price">2500 RON / Noapte</span></p>
        </div>

        <!-- Weekend Content -->
        <div class="pricing-content" id="content-weekend">
          <p class="pricing-days" data-i18n="rezerva.weekend_desc">Vineri — Duminică</p>
          <p class="pricing-price"><span class="shimmer-text" data-i18n="rezerva.weekend_price">3500 RON / Noapte</span></p>
        </div>

      </div>

      <!-- Decorative separator -->
      <div class="rezerva-separator slide-up" style="transition-delay: 0.6s;"></div>

      <!-- Static Meta Info -->
      <div class="rezerva-info-meta slide-up" style="transition-delay: 0.7s;">
        <div class="meta-highlight-group">
          <div class="meta-row">
            <span class="meta-accent">Check in:</span>
            <span class="meta-time">14:00</span>
          </div>
          <div class="meta-row">
            <span class="meta-accent">Check out:</span>
            <span class="meta-time">11:00</span>
          </div>
        </div>
        <p class="meta-sub" data-i18n="rezerva.reception_desc">Contactează recepția pentru prețuri și disponibilitate pe camere individuale.</p>
      </div>

      <!-- Action Buttons -->
      <div class="rezerva-actions-row slide-up" style="transition-delay: 0.85s;">
        <a href="https://www.booking.com/hotel/ro/chiba-chalet.ro.html?aid=318615&label=New_English_EN_RO_26745748345-fZgoCA7s4NgdMz81aMbHhAS640874805070%3Apl%3Ata%3Ap1%3Ap2%3Aac%3Aap%3Aneg%3Afi%3Atidsa-195218436025%3Alp1011804%3Ali%3Adec%3Adm%3Aag26745748345%3Acmp394170385&sid=b7f518a5d4dc23269ec3585410c17941&dest_id=900050014&dest_type=city&dist=0&group_adults=2&group_children=0&hapos=1&hpos=1&no_rooms=1&req_adults=2&req_children=0&room1=A%2CA&sb_price_type=total&sr_order=popularity&srepoch=1784461043&srpvid=54645199206202da&type=total&ucfs=1&" target="_blank" class="rezerva-icon-btn" title="Booking.com">
          <svg class="btn-icon-only" clip-rule="evenodd" fill-rule="evenodd" stroke-linejoin="round" stroke-miterlimit="1.414" viewBox="735 690 1500 1500" xmlns="http://www.w3.org/2000/svg">
            <!-- B. Text and Dot (White) -->
            <g fill-rule="nonzero">
              <path d="m1241.6 1768.638-220.052-.22v-263.12c0-56.22 21.808-85.48 69.917-92.165h150.136c107.068 0 176.328 67.507 176.328 176.766 0 112.219-67.507 178.63-176.328 178.739zm-220.052-709.694v-69.26c0-60.602 25.643-89.424 81.862-93.15h112.657c96.547 0 154.41 57.753 154.41 154.52 0 73.643-39.671 159.67-150.903 159.67h-198.026zm501.037 262.574-39.78-22.356 34.74-29.699c40.437-34.74 108.163-112.876 108.163-247.67 0-206.464-160.109-339.614-407.888-339.614h-282.738v-.11h-32.219c-73.424 2.74-132.273 62.466-133.04 136.329v1171.499h453.586c275.396 0 453.148-149.917 453.148-382.135 0-125.04-57.424-231.889-153.972-286.244" fill="#FFF"/>
              <path d="m1794.688 1828.066c0-89.492 72.178-161.894 161.107-161.894 89.154 0 161.669 72.402 161.669 161.894 0 89.379-72.515 161.894-161.67 161.894-88.928 0-161.106-72.515-161.106-161.894" fill="#FFF"/>
            </g>
          </svg>
          <span class="btn-glow"></span>
        </a>
        <a href="tel:+40000000000" class="rezerva-icon-btn" title="Sună recepția">
          <svg class="btn-icon-only" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Background bubble shape (white) to match the booking icon -->
            <rect width="24" height="24" rx="6" fill="#FFF"/>
            <!-- Phone Icon (green) -->
            <path d="M16.5 14.38c-.77 0-1.51-.12-2.21-.35-.22-.07-.47-.02-.65.15l-1.39 1.39c-1.81-.97-3.03-2.19-3.99-3.99l1.39-1.39c.17-.17.22-.42.15-.65-.23-.7-.35-1.44-.35-2.21 0-.41-.34-.75-.75-.75H6.12c-.41 0-.75.34-.75.75C5.37 13.56 10.44 18.63 17.88 18.63c.41 0 .75-.34.75-.75v-2.75c0-.41-.34-.75-.75-.75z" fill="var(--forest)"/>
          </svg>
          <span class="btn-glow"></span>
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  function initReservationsInteraction() {
    // 1. Scroll Animation (staggered reveal)
    const elements = document.querySelectorAll('#rezerva .slide-up');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    elements.forEach(el => observer.observe(el));

    // 2. Pill Toggle Logic
    const btnMidweek = document.getElementById('btn-midweek');
    const btnWeekend = document.getElementById('btn-weekend');
    const pillBg = document.getElementById('pill-bg');
    const contentMidweek = document.getElementById('content-midweek');
    const contentWeekend = document.getElementById('content-weekend');

    function switchTab(tab) {
      if (!btnMidweek || !btnWeekend || !pillBg || !contentMidweek || !contentWeekend) return;

      if (tab === 'midweek') {
        pillBg.style.transform = 'translateX(0)';
        btnMidweek.classList.add('active');
        btnWeekend.classList.remove('active');
        contentMidweek.classList.add('active');
        contentWeekend.classList.remove('active');
      } else {
        pillBg.style.transform = 'translateX(100%)';
        btnWeekend.classList.add('active');
        btnMidweek.classList.remove('active');
        contentWeekend.classList.add('active');
        contentMidweek.classList.remove('active');
      }
    }

    if (btnMidweek) btnMidweek.addEventListener('click', () => switchTab('midweek'));
    if (btnWeekend) btnWeekend.addEventListener('click', () => switchTab('weekend'));

    // 3. Floating Golden Particles
    const particlesContainer = document.getElementById('rezerva-particles');
    if (particlesContainer) {
      for (let i = 0; i < 20; i++) {
        const particle = document.createElement('div');
        particle.classList.add('r-particle');
        particle.style.left = Math.random() * 100 + '%';
        particle.style.animationDelay = Math.random() * 8 + 's';
        particle.style.animationDuration = (8 + Math.random() * 12) + 's';
        particle.style.width = (2 + Math.random() * 4) + 'px';
        particle.style.height = particle.style.width;
        particle.style.opacity = (0.15 + Math.random() * 0.35).toString();
        particlesContainer.appendChild(particle);
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReservationsInteraction);
  } else {
    initReservationsInteraction();
  }
</script>

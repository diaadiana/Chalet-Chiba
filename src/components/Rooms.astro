<section class="rooms" id="rooms">
  <div class="section-wrap rooms-wrap" style="padding-top: 0;">
    <div class="rooms-photo-grid">
      <div class="room-photo">
        <!-- Blue bird peaking from top-left of the first room photo -->
        <div class="about-blue-bird-wrapper">
          <img src="/images/pasere3.png" alt="Pasăre albastră decorativă" class="about-blue-bird" / loading="lazy" decoding="async">
        </div>
        <div class="room-photo-img-wrap">
          <img src="/images/rooms/557739044.webp" alt="Dormitor Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      </div>
      <div class="room-photo">
        <!-- Bird for mobile only on the 2nd photo (top-right corner of row 1) -->
        <div class="about-blue-bird-wrapper-tr bird-mob-only">
          <img src="/images/pasere5.png" alt="Pasăre verde decorativă" class="about-blue-bird-tr" / loading="lazy" decoding="async">
        </div>
        <div class="room-photo-img-wrap">
          <img src="/images/rooms/736420508.webp" alt="Dormitor Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      </div>
      <div class="room-photo">
        <!-- Bird for desktop only on the 3rd photo (top-right corner of row 1) -->
        <div class="about-blue-bird-wrapper-tr bird-desk-only">
          <img src="/images/pasere5.png" alt="Pasăre verde decorativă" class="about-blue-bird-tr" / loading="lazy" decoding="async">
        </div>
        <div class="room-photo-img-wrap">
          <img src="/images/rooms/736422131.webp" alt="Dormitor Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      </div>
      <div class="room-photo">
        <div class="room-photo-img-wrap">
          <img src="/images/rooms/Chiba-36.webp" alt="Dormitor Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      </div>
      <div class="room-photo">
        <div class="room-photo-img-wrap">
          <img src="/images/rooms/Chiba-44.webp" alt="Dormitor Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      </div>
      <div class="room-photo">
        <div class="room-photo-img-wrap">
          <img src="/images/rooms/Chiba-47.webp" alt="Dormitor Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>

    <!-- Minimalist details layout -->
    <div class="rooms-details-container">
      <div class="room-detail-card">
        <div class="room-count">3</div>
        <div class="room-info-text">
          <h3 class="room-detail-title" data-i18n="rooms.matrimonial_title">Camere Matrimoniale cu baie</h3>
          <p class="room-detail-desc" data-i18n="rooms.matrimonial_desc">Un refugiu elegant cu decor rustic, spațiu generos pentru odihnă și baie privată complet utilată, ideală pentru relaxare.</p>
        </div>
      </div>

      <div class="room-detail-card">
        <div class="room-count">2</div>
        <div class="room-info-text">
          <h3 class="room-detail-title" data-i18n="rooms.apartment_title">Apartamente (două camere cu baie)</h3>
          <p class="room-detail-desc" data-i18n="rooms.apartment_desc">Îmbină decorul rustic cu spațiul generos. Dispun de un dormitor principal, un living confortabil și baie modernă, fiind ideale pentru familii sau grupuri.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .rooms {
    min-height: 100vh;
    box-sizing: border-box;
    display: flex;
    align-items: center; /* centers the content vertically */
    justify-content: center; /* centers the content horizontally */
    padding: 7rem 0 3rem 0; /* added 7rem top padding to push it slightly below the sticky navbar */
    background: var(--cream);
  }
  .rooms-wrap {
    max-width: 900px;
    width: 100%;
    margin: auto 0; /* vertical margin auto to center nicely */
    padding: 0 24px;
    padding-right: 64px; /* extra right padding to allow bird to peek outside the grid */
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    overflow: visible;
  }
  .rooms-photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    width: 100%;
    overflow: visible;
  }
  .room-photo {
    width: 100%;
    aspect-ratio: 3 / 1.7; /* Sightly wider and shorter to save vertical height */
    position: relative;
    overflow: visible; /* Changed to allow bird to overlap outside container */
  }
  .room-photo-img-wrap {
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
  }
  .room-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .room-photo:hover img {
    transform: scale(1.05);
  }

  /* Blue bird peaking from top-left of hallway photo in Rooms section */
  .about-blue-bird-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 5.5rem;
    height: 5.5rem;
    z-index: 3; /* On top of the image wrap to prevent clipping */
    transform: translate(-30%, -30%) rotate(0deg);
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }

  .about-blue-bird {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transform-origin: bottom right;
    display: block;
  }

  .room-photo:hover .about-blue-bird-wrapper {
    transform: translate(-58%, -58%) rotate(-12deg);
  }

  .about-blue-bird-wrapper-tr {
    position: absolute;
    top: 0;
    right: 0;
    width: 6.5rem;
    height: 6.5rem;
    z-index: 3; /* On top of the image wrap to prevent clipping */
    transform: translate(48%, -30%) rotate(0deg);
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }

  .about-blue-bird-tr {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transform-origin: bottom left;
    display: block;
  }

  .room-photo:hover .about-blue-bird-wrapper-tr {
    transform: translate(65%, -58%) rotate(12deg);
  }

  .bird-mob-only {
    display: none !important;
  }
  .bird-desk-only {
    display: flex !important;
  }

  /* Room details container */
  .rooms-details-container {
    display: flex;
    gap: 3rem;
    width: 100%;
    margin-top: 0.5rem;
  }
  .room-detail-card {
    flex: 1;
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .room-count {
    font-family: 'Cinzel', serif;
    font-size: 2.2rem;
    font-weight: 400;
    color: var(--gold);
    line-height: 1;
    border-bottom: 2px solid var(--gold);
    padding-bottom: 2px;
  }
  .room-info-text {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .room-detail-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--forest);
    margin: 0;
  }
  .room-detail-desc {
    font-family: 'Jost', sans-serif;
    font-size: 0.84rem;
    line-height: 1.5;
    color: #666;
    margin: 0;
  }

  @media (max-width: 900px) {
    .rooms {
      min-height: auto;
      padding: 4rem 0; /* remove horizontal padding to let rooms-wrap manage it symmetrically */
    }
    .rooms-wrap {
      padding: 0 24px !important; /* symmetric horizontal padding centers the grid perfectly */
      margin: 0 auto;
    }
    .rooms-photo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .rooms-details-container {
      flex-direction: column;
      gap: 1.8rem;
      margin-top: 2rem; /* adds clean spacing below the grid */
      padding: 0;
    }
  }
  @media (max-width: 600px) {
    .rooms-wrap {
      padding: 0 16px !important; /* wider grid on small mobile screens */
    }
    .rooms-photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .bird-mob-only {
      display: flex !important; /* show bird in 2nd column top-right of row 1 */
    }
    .bird-desk-only {
      display: none !important; /* hide bird in 3rd column since it wrapped to row 2 */
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initRoomsBird() {
    // Prima pasăre (stânga sus)
    gsap.fromTo(".rooms .about-blue-bird", {
      scale: 0.7,
      x: 35,
      y: 35,
      opacity: 0
    }, {
      scale: 1,
      x: 0,
      y: 0,
      opacity: 1,
      ease: "back.out(1.5)",
      duration: 1.2,
      scrollTrigger: {
        trigger: ".rooms-photo-grid",
        start: "top 85%",
        toggleActions: "play none none none"
      }
    });

    // A doua pasăre (dreapta sus)
    gsap.fromTo(".rooms .about-blue-bird-tr", {
      scale: 0.7,
      x: -35,
      y: 35,
      opacity: 0
    }, {
      scale: 1,
      x: 0,
      y: 0,
      opacity: 1,
      ease: "back.out(1.5)",
      duration: 1.2,
      scrollTrigger: {
        trigger: ".rooms-photo-grid",
        start: "top 85%",
        toggleActions: "play none none none"
      }
    });
  }

  // Delay slightly to ensure elements are rendered
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initRoomsBird);
  } else {
    initRoomsBird();
  }
</script>

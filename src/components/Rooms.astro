---
<section class="rooms" id="rooms">
  <div class="section-wrap rooms-wrap" style="padding-top: 0;">
    <div class="rooms-photo-grid">
      <div class="room-photo">
        <img src="/images/rooms/557739044.jpg" alt="Dormitor Chalet Chiba" loading="lazy" />
      </div>
      <div class="room-photo">
        <img src="/images/rooms/736420508.jpg" alt="Dormitor Chalet Chiba" loading="lazy" />
      </div>
      <div class="room-photo">
        <img src="/images/rooms/736422131.jpg" alt="Dormitor Chalet Chiba" loading="lazy" />
      </div>
      <div class="room-photo">
        <img src="/images/rooms/Chiba-36.jpg" alt="Dormitor Chalet Chiba" loading="lazy" />
      </div>
      <div class="room-photo">
        <img src="/images/rooms/Chiba-44.jpg" alt="Dormitor Chalet Chiba" loading="lazy" />
      </div>
      <div class="room-photo">
        <img src="/images/rooms/Chiba-47.jpg" alt="Dormitor Chalet Chiba" loading="lazy" />
      </div>
    </div>

    <!-- Minimalist details layout -->
    <div class="rooms-details-container">
      <div class="room-detail-card">
        <div class="room-count">3</div>
        <div class="room-info-text">
          <h3 class="room-detail-title" data-i18n="rooms.matrimonial_title">Camere Matrimoniale cu baie</h3>
          <p class="room-detail-desc" data-i18n="rooms.matrimonial_desc">Un refugiu elegant cu decor rustic, pat king-size confortabil și baie privată complet utilată, ideală pentru relaxare.</p>
        </div>
      </div>

      <div class="room-detail-card">
        <div class="room-count">2</div>
        <div class="room-info-text">
          <h3 class="room-detail-title" data-i18n="rooms.apartment_title">Apartamente (două camere cu baie)</h3>
          <p class="room-detail-desc" data-i18n="rooms.apartment_desc">Îmbină decorul rustic cu spațiul generos. Dispun de un dormitor principal, un living confortabil și baie modernă, fiind ideale pentru familii sau grupuri.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .rooms {
    min-height: 100vh;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 0;
    background: var(--cream);
  }
  .rooms-wrap {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .rooms-photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    width: 100%;
  }
  .room-photo {
    width: 100%;
    aspect-ratio: 3 / 1.7; /* Sightly wider and shorter to save vertical height */
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
  }
  .room-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .room-photo:hover img {
    transform: scale(1.05);
  }

  /* Room details container */
  .rooms-details-container {
    display: flex;
    gap: 3rem;
    width: 100%;
    margin-top: 0.5rem;
  }
  .room-detail-card {
    flex: 1;
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .room-count {
    font-family: 'Cinzel', serif;
    font-size: 2.2rem;
    font-weight: 400;
    color: var(--gold);
    line-height: 1;
    border-bottom: 2px solid var(--gold);
    padding-bottom: 2px;
  }
  .room-info-text {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .room-detail-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--forest);
    margin: 0;
  }
  .room-detail-desc {
    font-family: 'Jost', sans-serif;
    font-size: 0.84rem;
    line-height: 1.5;
    color: #666;
    margin: 0;
  }

  @media (max-width: 900px) {
    .rooms {
      min-height: auto;
      padding: 4rem 1.8rem;
    }
    .rooms-photo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .rooms-details-container {
      flex-direction: column;
      gap: 1.5rem;
    }
  }
  @media (max-width: 600px) {
    .rooms-photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

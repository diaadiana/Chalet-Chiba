---
<section id="gallery" class="gallery-section">
  <!-- Universal Fan Carousel -->
  <div class="gallery-carousel-fan-container">
    <button class="gallery-nav prev" aria-label="Poza anterioara">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    
    <div class="gallery-carousel-fan">
      {images.map(src => (
        <div class="carousel-item">
          <img src={src} alt="Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>

    <button class="gallery-nav next" aria-label="Urmatoarea poza">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>
</section>

<style>
  .gallery-carousel-fan-container {
    position: relative;
    width: 100%;
    height: 600px;
    overflow: visible;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .gallery-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    /* Efect Glassmorphism adaptiv (alb/inghetat) */
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);
    color: #fff;
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 50;
    transition: all 0.3s ease;
  }
  
  .gallery-nav:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: var(--gold, #B8955A);
    color: var(--gold, #B8955A);
    transform: translateY(-50%) scale(1.05);
  }

  .gallery-nav:active {
    transform: translateY(-50%) scale(0.95);
  }
  
  .gallery-nav svg {
    width: 28px;
    height: 28px;
  }
  
  .gallery-nav.prev {
    left: 4rem;
  }
  
  .gallery-nav.next {
    right: 4rem;
  }

  /* Mobile adjustments */
  @media (max-width: 900px) {
    .gallery-carousel-fan-container {
      height: 480px; 
    }
    .gallery-nav {
      display: flex;
      width: 44px;
      height: 44px;
    }
    .gallery-nav svg {
      width: 24px;
      height: 24px;
    }
    .gallery-nav.prev {
      left: 1rem;
    }
    .gallery-nav.next {
      right: 1rem;
    }
  }
</style>

<script>
  function initGalleryAnimation() {
    const container = document.querySelector('.gallery-carousel-fan-container') as HTMLElement;
    const items = container?.querySelectorAll('.carousel-item');
    const btnPrev = document.querySelector('.gallery-nav.prev');
    const btnNext = document.querySelector('.gallery-nav.next');

    if (!container || !items || items.length === 0) return;

    let currentIndex = Math.floor(items.length / 2);
    let autoplayTimer: any = null;

    function updateCarousel() {
      items.forEach((item, index) => {
        const el = item as HTMLElement;
        let offset = index - currentIndex;
        const total = items.length;
        let pos = (offset + total) % total;
        if (pos > Math.floor(total / 2)) {
          pos = pos - total;
        }

        const isCenter = pos === 0;
        const isAdjacent = Math.abs(pos) === 1;
        
        let translateX = pos * 85; 
        let rotate = pos * 8; 
        let scale = isCenter ? 1 : isAdjacent ? 0.85 : 0.7;

        el.style.transform = `
          translateX(${translateX}%) 
          rotate(${rotate}deg)
          scale(${scale})
        `;
        
        el.style.zIndex = isCenter ? '10' : isAdjacent ? '5' : '1';
        el.style.opacity = isCenter ? '1' : isAdjacent ? '0.7' : '0.4';
        el.style.filter = isCenter ? 'blur(0px)' : isAdjacent ? 'blur(3px)' : 'blur(6px)';
        el.style.visibility = Math.abs(pos) > 2 ? 'hidden' : 'visible';
        el.style.cursor = isCenter ? 'default' : 'pointer';
      });
    }

    function handleNext() {
      currentIndex = (currentIndex + 1) % items.length;
      updateCarousel();
    }

    function handlePrev() {
      currentIndex = (currentIndex - 1 + items.length) % items.length;
      updateCarousel();
    }

    // Click on side images to activate them
    items.forEach((item, index) => {
      (item as HTMLElement).addEventListener('click', (e) => {
        if (index !== currentIndex) {
          e.preventDefault();
          currentIndex = index;
          updateCarousel();
          resetAutoplay();
        }
      });
    });

    // Navigation buttons (for mobile)
    if (btnNext) {
      btnNext.addEventListener('click', (e) => {
        e.stopPropagation();
        handleNext();
        resetAutoplay();
      });
    }
    if (btnPrev) {
      btnPrev.addEventListener('click', (e) => {
        e.stopPropagation();
        handlePrev();
        resetAutoplay();
      });
    }

    // Mouse drag support for desktop
    let startX = 0;
    let isDragging = false;

    container.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
    });

    container.addEventListener('mouseup', (e) => {
      if (!isDragging) return;
      isDragging = false;
      const diffX = e.clientX - startX;
      if (diffX < -40) {
        handleNext();
        resetAutoplay();
      } else if (diffX > 40) {
        handlePrev();
        resetAutoplay();
      }
    });

    container.addEventListener('mouseleave', () => {
      isDragging = false;
    });

    // Touch swipe support
    container.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
    }, { passive: true });

    container.addEventListener('touchend', (e) => {
      const endX = e.changedTouches[0].clientX;
      const diffX = endX - startX;
      if (diffX < -40) {
        handleNext();
        resetAutoplay();
      } else if (diffX > 40) {
        handlePrev();
        resetAutoplay();
      }
    }, { passive: true });

    // Autoplay (derulare automata pe desktop si mobil)
    function startAutoplay() {
      stopAutoplay();
      autoplayTimer = setInterval(handleNext, 3500);
    }

    function stopAutoplay() {
      if (autoplayTimer) clearInterval(autoplayTimer);
    }

    function resetAutoplay() {
      stopAutoplay();
      startAutoplay();
    }

    container.addEventListener('mouseenter', stopAutoplay);
    container.addEventListener('mouseleave', startAutoplay);

    updateCarousel();
    startAutoplay();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGalleryAnimation);
  } else {
    initGalleryAnimation();
  }
</script>

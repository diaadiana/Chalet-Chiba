---
const images = [
  "/images/about/IMG-20240725-WA0001.webp",
  "/images/about/IMG-20240725-WA0021.webp",
  "/images/about/IMG-20240725-WA0024.webp",
  "/images/about/IMG-20240725-WA0026.webp",
  "/images/about/IMG-20240725-WA0036.webp",
  "/images/about/IMG-20240725-WA0052.webp",
  "/images/about/IMG-20240725-WA0057.webp",
  "/images/about/IMG-20240725-WA0059.webp",
  "/images/about/IMG-20240725-WA0061.webp",
  "/images/about/IMG-20240725-WA0066.webp",
  "/images/about/Chiba-25.webp",
  "/images/about/557739044.webp",
  "/images/about/557739065.webp",
  "/images/about/622936369.webp",
  "/images/about/736420433.webp",
  "/images/about/736420508.webp",
  "/images/about/736420520.webp",
  "/images/about/736420746.webp",
  "/images/about/736420785.webp"
];
---
<section id="gallery" class="gallery-section">
  <!-- Desktop: Full-page Fan Carousel -->
  <div class="gallery-carousel-fan-container desktop-carousel">
    <div class="gallery-carousel-fan">
      {images.map(src => (
        <div class="carousel-item">
          <img src={src} alt="Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>

  <!-- Mobile: Stacked Clip-Path Reveal Gallery -->
  <div class="stacked-gallery-wrapper mobile-gallery" id="portfolio">
    {images.map((src, index) => (
      <div class="stacked-item" style={`z-index: ${images.length - index}`}>
        <div class="stacked-img-wrap">
           <img src={src} alt="Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  /* Base Desktop Styles */
  .mobile-gallery {
    display: none;
  }
  .desktop-carousel {
    display: block;
  }
  .gallery-carousel-fan-container {
    position: relative;
    width: 100%;
    height: 525px;
    overflow: visible;
    margin-top: -55px;
  }
  
  /* Mobile Styles */
  @media (max-width: 768px) {
    .desktop-carousel {
      display: none;
    }
    .mobile-gallery {
      display: block;
      width: 100%;
      height: 100svh; /* svh is better for mobile browsers */
      position: relative;
      overflow: hidden;
      /* Remove padding or flex that would break the absolute stacking */
    }
    .stacked-item {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      will-change: clip-path; /* Optimized for animation */
      clip-path: inset(0 0 0% 0);
    }
    .stacked-img-wrap {
      width: 100%;
      height: 100%;
      position: relative;
      overflow: hidden;
      will-change: transform; /* Optimized for animation */
    }
    .stacked-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transform: scale(1);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initGalleryAnimation() {
    let mm = gsap.matchMedia();

    // Desktop: Fan Carousel
    mm.add("(min-width: 769px)", () => {
      const section = document.querySelector('.desktop-carousel');
      const items = section?.querySelectorAll('.carousel-item');
      let intervalId: any;

      if (items && items.length > 0) {
        let currentIndex = Math.floor(items.length / 2);

        function updateCarousel() {
          items.forEach((item, index) => {
            const el = item as HTMLElement;
            let offset = index - currentIndex;
            const total = items.length;
            let pos = (offset + total) % total;
            if (pos > Math.floor(total / 2)) {
              pos = pos - total;
            }

            const isCenter = pos === 0;
            const isAdjacent = Math.abs(pos) === 1;
            const isFar = Math.abs(pos) > 1;

            el.style.transform = `
              translateX(${pos * 100}%) 
              translateY(0%)
              translateZ(0px)
              rotate(0deg)
              scale(${isCenter ? 1 : isAdjacent ? 0.85 : 0.7})
            `;
            
            el.style.zIndex = isCenter ? '10' : isAdjacent ? '5' : '1';
            el.style.opacity = isCenter ? '1' : isAdjacent ? '0.7' : '0.4';
            el.style.filter = isCenter ? 'blur(0px)' : isAdjacent ? 'blur(3px)' : 'blur(6px)';
            el.style.visibility = Math.abs(pos) > 2 ? 'hidden' : 'visible';
          });
        }

        function handleNext() {
          currentIndex = (currentIndex + 1) % items.length;
          updateCarousel();
        }

        updateCarousel();
        intervalId = setInterval(handleNext, 4000);
      }

      return () => {
        if (intervalId) clearInterval(intervalId);
      };
    });

    // Mobile: Stacked Clip-Path Reveal Gallery
    mm.add("(max-width: 768px)", () => {
      const wrapper = document.querySelector('.stacked-gallery-wrapper');
      const items = gsap.utils.toArray('.stacked-item');
      
      if (!wrapper || items.length === 0) return;

      // Create a master timeline pinned to the wrapper
      // Let's use 45% of viewport height per item to keep it fast but controllable.
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: wrapper,
          pin: true,
          scrub: 1, // Smooth scrub
          start: "top top",
          end: () => `+=${items.length * window.innerHeight * 0.45}`, 
          invalidateOnRefresh: true
        }
      });

      // We animate each item EXCEPT the last one to clip from bottom to top
      items.forEach((item: any, i) => {
        if (i === items.length - 1) return; // The bottom-most item stays

        const imgWrap = item.querySelector('.stacked-img-wrap');

        // Animate the clip-path wiping UP (100% means bottom is clipped fully to top)
        tl.to(item, {
          clipPath: "inset(0 0 100% 0)", 
          ease: "none"
        }, i); // Use 'i' to sequence them linearly
        
        // Optional: Animate the image wrap scaling UP slightly for a parallax feel
        if (imgWrap) {
           tl.to(imgWrap, {
             scale: 1.15,
             ease: "none"
           }, i);
        }
      });

      return () => {
        // Cleanup listener on unmatch automatically handled by gsap.matchMedia()
      };
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGalleryAnimation);
  } else {
    initGalleryAnimation();
  }
</script>

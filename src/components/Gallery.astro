---
const images = [
  "/images/about/IMG-20240725-WA0001.webp",
  "/images/about/IMG-20240725-WA0021.webp",
  "/images/about/IMG-20240725-WA0024.webp",
  "/images/about/IMG-20240725-WA0026.webp",
  "/images/about/IMG-20240725-WA0036.webp",
  "/images/about/IMG-20240725-WA0052.webp",
  "/images/about/IMG-20240725-WA0057.webp",
  "/images/about/IMG-20240725-WA0059.webp",
  "/images/about/IMG-20240725-WA0061.webp",
  "/images/about/IMG-20240725-WA0066.webp",
  "/images/about/Chiba-25.webp",
  "/images/about/557739044.webp",
  "/images/about/557739065.webp",
  "/images/about/622936369.webp",
  "/images/about/736420433.webp",
  "/images/about/736420508.webp",
  "/images/about/736420520.webp",
  "/images/about/736420746.webp",
  "/images/about/736420785.webp"
];
---
<section id="gallery" class="gallery-section">
  <!-- Desktop: Full-page Fan Carousel -->
  <div class="gallery-carousel-fan-container desktop-carousel">
    <div class="gallery-carousel-fan">
      {images.map(src => (
        <div class="carousel-item">
          <img src={src} alt="Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>

  <!-- Mobile: Stacked Fly-Off Gallery -->
  <div class="mobile-gallery" id="portfolio">
    <div class="swipe-message">Trage în orice direcție pentru a vedea galeria</div>
    <div class="stacked-gallery-container">
      {images.map((src, index) => (
        <div class="stacked-item" style={`z-index: ${images.length - index}`}>
           <img src={src} alt="Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Base Desktop Styles */
  .mobile-gallery {
    display: none;
  }
  .desktop-carousel {
    display: block;
  }
  .gallery-carousel-fan-container {
    position: relative;
    width: 100%;
    height: 525px;
    overflow: visible;
    margin-top: -55px;
  }
  /* Mobile Styles */
  @media (max-width: 768px) {
    .desktop-carousel {
      display: none;
    }
    .mobile-gallery {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      width: 100%;
      height: 100svh; 
      box-sizing: border-box;
      position: relative;
      overflow: hidden;
      padding-top: 65px; /* Offset the sticky navigation bar */
    }
    .swipe-message {
      position: relative; 
      bottom: auto;
      left: auto;
      transform: none;
      font-family: 'Jost', sans-serif;
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--forest, #1A3A1A); 
      pointer-events: none;
      animation: pulseText 2s infinite;
      text-align: center;
      width: 100%;
      z-index: 100;
      margin-bottom: 20px; 
    }
    .stacked-gallery-container {
      position: relative;
      width: 92vw; 
      height: 72svh; 
      perspective: 1000px;
      margin: 0;
      padding: 0;
    }
    .stacked-item {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border-radius: 20px; 
      box-shadow: 0 10px 30px rgba(0,0,0,0.2); 
      will-change: transform, opacity;
      transform-origin: center center;
      background: transparent;
      border: none;
      /* Previne scroll-ul accidental cand tragi de poze */
      touch-action: none; 
    }
    .stacked-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      border-radius: 20px; 
    }
    @keyframes pulseText {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 0.9; }
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initGalleryAnimation() {
    let mm = gsap.matchMedia();

    // Desktop: Fan Carousel
    mm.add("(min-width: 769px)", () => {
      const section = document.querySelector('.desktop-carousel');
      const items = section?.querySelectorAll('.carousel-item');
      let intervalId: any;

      if (items && items.length > 0) {
        let currentIndex = Math.floor(items.length / 2);

        function updateCarousel() {
          items.forEach((item, index) => {
            const el = item as HTMLElement;
            let offset = index - currentIndex;
            const total = items.length;
            let pos = (offset + total) % total;
            if (pos > Math.floor(total / 2)) {
              pos = pos - total;
            }

            const isCenter = pos === 0;
            const isAdjacent = Math.abs(pos) === 1;
            const isFar = Math.abs(pos) > 1;

            el.style.transform = `
              translateX(${pos * 100}%) 
              translateY(0%)
              translateZ(0px)
              rotate(0deg)
              scale(${isCenter ? 1 : isAdjacent ? 0.85 : 0.7})
            `;
            
            el.style.zIndex = isCenter ? '10' : isAdjacent ? '5' : '1';
            el.style.opacity = isCenter ? '1' : isAdjacent ? '0.7' : '0.4';
            el.style.filter = isCenter ? 'blur(0px)' : isAdjacent ? 'blur(3px)' : 'blur(6px)';
            el.style.visibility = Math.abs(pos) > 2 ? 'hidden' : 'visible';
          });
        }

        function handleNext() {
          currentIndex = (currentIndex + 1) % items.length;
          updateCarousel();
        }

        updateCarousel();
        intervalId = setInterval(handleNext, 4000);
      }

      return () => {
        if (intervalId) clearInterval(intervalId);
      };
    });

    // Mobile: Interactive Swipe / Drag Gallery with Scroll Pin
    mm.add("(max-width: 768px)", () => {
      const wrapper = document.querySelector('.mobile-gallery');
      const section = document.querySelector('#gallery');
      const items = gsap.utils.toArray('.stacked-item');
      
      if (!wrapper || !section || items.length === 0) return;

      // Pin the gallery section so it locks in place
      let galleryPin = ScrollTrigger.create({
        trigger: section,
        pin: true,
        start: "top top",
        end: "+=4000", // Keep pinned securely for a long scroll distance
        invalidateOnRefresh: true,
      });

      const message = wrapper.querySelector('.swipe-message');

      let currentIndex = 0;
      let isDragging = false;
      let startX = 0, startY = 0;
      let currentX = 0, currentY = 0;
      let activeItem: any = null;

      // Touch events for premium drag physics
      wrapper.addEventListener('touchstart', (e: any) => {
        if (currentIndex >= items.length - 1) return;
        isDragging = true;
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        currentX = startX;
        currentY = startY;
        activeItem = items[currentIndex];
        
        // Opreste orice animatie in curs pentru a urmari degetul instant
        gsap.killTweensOf(activeItem);
      }, { passive: true });

      wrapper.addEventListener('touchmove', (e: any) => {
        if (!isDragging || !activeItem) return;
        currentX = e.touches[0].clientX;
        currentY = e.touches[0].clientY;
        
        let deltaX = currentX - startX;
        let deltaY = currentY - startY;
        let rot = deltaX * 0.05; // Rotatie fina in functie de tragere

        // Cardul urmareste degetul finut
        gsap.set(activeItem, {
          x: deltaX,
          y: deltaY,
          rotationZ: rot
        });
      }, { passive: true });

      wrapper.addEventListener('touchend', (e: any) => {
        if (!isDragging || !activeItem) return;
        isDragging = false;

        let deltaX = currentX - startX;
        let deltaY = currentY - startY;
        let distance = Math.sqrt(deltaX * deltaX + deltaY * deltaY);

        // Daca a tras suficient de tare (prag de 80px)
        if (distance > 80) {
          let factor = Math.max(window.innerWidth, window.innerHeight) / (distance || 1);
          gsap.to(activeItem, {
            x: deltaX * factor,
            y: deltaY * factor,
            rotationZ: deltaX * 0.1,
            opacity: 0,
            duration: 0.6,
            ease: "power2.out",
            onComplete: () => {
              if (activeItem) activeItem.style.display = 'none';
            }
          });
          
          currentIndex++;

          // Daca am ajuns la ultima poza, dezactivam blocajul (Scroll Pin)
          if (currentIndex >= items.length - 1) {
             if (galleryPin) {
                galleryPin.kill(); // Elibereaza scroll-ul!
             }
             if (message) {
                gsap.to(message, { opacity: 0, duration: 0.5 }); // Ascunde mesajul
             }
          }

        } else {
          // Snap inapoi lin daca nu a tras suficient
          gsap.to(activeItem, {
            x: 0,
            y: 0,
            rotationZ: 0,
            duration: 0.5,
            ease: "back.out(1.2)"
          });
        }
        
        activeItem = null;
      }, { passive: true });

      // Mouse events for testing / desktop touch emulation
      wrapper.addEventListener('mousedown', (e: any) => {
        if (currentIndex >= items.length - 1) return;
        isDragging = true;
        startX = e.clientX;
        startY = e.clientY;
        currentX = startX;
        currentY = startY;
        activeItem = items[currentIndex];
        gsap.killTweensOf(activeItem);
      });

      wrapper.addEventListener('mousemove', (e: any) => {
        if (!isDragging || !activeItem) return;
        currentX = e.clientX;
        currentY = e.clientY;
        let deltaX = currentX - startX;
        let deltaY = currentY - startY;
        let rot = deltaX * 0.05;
        gsap.set(activeItem, { x: deltaX, y: deltaY, rotationZ: rot });
      });

      wrapper.addEventListener('mouseup', (e: any) => {
        if (!isDragging || !activeItem) return;
        isDragging = false;
        let deltaX = currentX - startX;
        let deltaY = currentY - startY;
        let distance = Math.sqrt(deltaX * deltaX + deltaY * deltaY);

        if (distance > 80) {
          let factor = Math.max(window.innerWidth, window.innerHeight) / (distance || 1);
          gsap.to(activeItem, {
            x: deltaX * factor,
            y: deltaY * factor,
            rotationZ: deltaX * 0.1,
            opacity: 0,
            duration: 0.6,
            ease: "power2.out",
            onComplete: () => { if (activeItem) activeItem.style.display = 'none'; }
          });
          currentIndex++;
          
          if (currentIndex >= items.length - 1) {
             if (galleryPin) galleryPin.kill();
             if (message) gsap.to(message, { opacity: 0, duration: 0.5 });
          }
        } else {
          gsap.to(activeItem, { x: 0, y: 0, rotationZ: 0, duration: 0.5, ease: "back.out(1.2)" });
        }
        activeItem = null;
      });
      
      wrapper.addEventListener('mouseleave', (e: any) => {
         if (isDragging) wrapper.dispatchEvent(new Event('mouseup'));
      });

      return () => {
        if (galleryPin) galleryPin.kill();
      };
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGalleryAnimation);
  } else {
    initGalleryAnimation();
  }
</script>

---
const images = [
  "/images/about/IMG-20240725-WA0001.webp",
  "/images/about/IMG-20240725-WA0021.webp",
  "/images/about/IMG-20240725-WA0024.webp",
  "/images/about/IMG-20240725-WA0026.webp",
  "/images/about/IMG-20240725-WA0036.webp",
  "/images/about/IMG-20240725-WA0052.webp",
  "/images/about/IMG-20240725-WA0057.webp",
  "/images/about/IMG-20240725-WA0059.webp",
  "/images/about/IMG-20240725-WA0061.webp",
  "/images/about/IMG-20240725-WA0066.webp",
  "/images/about/Chiba-25.webp",
  "/images/about/557739044.webp",
  "/images/about/557739065.webp",
  "/images/about/622936369.webp",
  "/images/about/736420433.webp",
  "/images/about/736420508.webp",
  "/images/about/736420520.webp",
  "/images/about/736420746.webp",
  "/images/about/736420785.webp"
];
---
<section id="gallery" class="gallery-section">
  <!-- Desktop: Full-page Fan Carousel -->
  <div class="gallery-carousel-fan-container desktop-carousel">
    <div class="gallery-carousel-fan">
      {images.map(src => (
        <div class="carousel-item">
          <img src={src} alt="Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>

  <!-- Mobile: Stacked Fly-Off Gallery -->
  <div class="mobile-gallery" id="portfolio">
    <div class="stacked-gallery-container">
      {images.map((src, index) => (
        <div class="stacked-item" style={`z-index: ${images.length - index}`}>
           <img src={src} alt="Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Base Desktop Styles */
  .mobile-gallery {
    display: none;
  }
  .desktop-carousel {
    display: block;
  }
  .gallery-carousel-fan-container {
    position: relative;
    width: 100%;
    height: 525px;
    overflow: visible;
    margin-top: -55px;
  }
  
  /* Mobile Styles */
  @media (max-width: 768px) {
    .desktop-carousel {
      display: none;
    }
    .mobile-gallery {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
      height: 100svh;
      position: relative;
      /* Remove overflow:hidden to prevent any misalignment; it will just overlay perfectly */
    }
    .stacked-gallery-container {
      position: relative;
      width: 75vw;
      height: 55svh; /* slightly smaller to look more like a card */
      perspective: 1000px;
      margin: 0;
      padding: 0;
    }
    .stacked-item {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border-radius: 20px; 
      /* Extremely subtle shadow to prevent black blob when 19 cards are stacked */
      box-shadow: 0 8px 24px rgba(0,0,0,0.03); 
      will-change: transform, opacity;
      transform-origin: center center;
      
      /* Clean Glassmorphism Frame */
      background: rgba(255, 255, 255, 0.35); /* Elegant translucent white */
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.7); /* Crisp border */
      padding: 12px; /* The white/glass margin around the image */
    }
    .stacked-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      border-radius: 14px; /* Inner radius for the image */
      background: transparent;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initGalleryAnimation() {
    let mm = gsap.matchMedia();

    // Desktop: Fan Carousel
    mm.add("(min-width: 769px)", () => {
      const section = document.querySelector('.desktop-carousel');
      const items = section?.querySelectorAll('.carousel-item');
      let intervalId: any;

      if (items && items.length > 0) {
        let currentIndex = Math.floor(items.length / 2);

        function updateCarousel() {
          items.forEach((item, index) => {
            const el = item as HTMLElement;
            let offset = index - currentIndex;
            const total = items.length;
            let pos = (offset + total) % total;
            if (pos > Math.floor(total / 2)) {
              pos = pos - total;
            }

            const isCenter = pos === 0;
            const isAdjacent = Math.abs(pos) === 1;
            const isFar = Math.abs(pos) > 1;

            el.style.transform = `
              translateX(${pos * 100}%) 
              translateY(0%)
              translateZ(0px)
              rotate(0deg)
              scale(${isCenter ? 1 : isAdjacent ? 0.85 : 0.7})
            `;
            
            el.style.zIndex = isCenter ? '10' : isAdjacent ? '5' : '1';
            el.style.opacity = isCenter ? '1' : isAdjacent ? '0.7' : '0.4';
            el.style.filter = isCenter ? 'blur(0px)' : isAdjacent ? 'blur(3px)' : 'blur(6px)';
            el.style.visibility = Math.abs(pos) > 2 ? 'hidden' : 'visible';
          });
        }

        function handleNext() {
          currentIndex = (currentIndex + 1) % items.length;
          updateCarousel();
        }

        updateCarousel();
        intervalId = setInterval(handleNext, 4000);
      }

      return () => {
        if (intervalId) clearInterval(intervalId);
      };
    });

    // Mobile: Random Fly-Off Gallery
    mm.add("(max-width: 768px)", () => {
      const wrapper = document.querySelector('.mobile-gallery');
      const section = document.querySelector('#gallery');
      const items = gsap.utils.toArray('.stacked-item');
      
      if (!wrapper || !section || items.length === 0) return;

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section, // pin the whole section to avoid flex child layout breaks
          pin: true,
          scrub: 1.5, // Increase scrub to make it smoother and prevent flying through multiple cards instantly
          start: "top top", 
          // Increase end distance significantly so that one full scroll swipe naturally moves 1 card
          end: () => `+=${items.length * window.innerHeight * 1.2}`, 
          invalidateOnRefresh: true,
          snap: {
            snapTo: "labels", // Snap perfectly to each card
            duration: { min: 0.3, max: 0.8 },
            delay: 0.05,
            ease: "power2.inOut"
          }
        }
      });

      items.forEach((item: any, i) => {
        if (i === items.length - 1) return; // The bottom-most item stays
        
        // Add label for snapping
        tl.addLabel("card" + i, i);

        // Pre-calculate random target position outside the viewport
        const angle = Math.random() * Math.PI * 2;
        const radius = Math.max(window.innerWidth, window.innerHeight) * 1.2;
        const tx = Math.cos(angle) * radius;
        const ty = Math.sin(angle) * radius;
        
        const rot = (Math.random() - 0.5) * 90;

        tl.to(item, {
          x: tx,
          y: ty,
          rotationZ: rot,
          opacity: 0,
          ease: "power1.inOut"
        }, i); // sequence linearly at exactly time "i"
      });
      
      // Add a final label at the end so the last card snaps correctly too
      tl.addLabel("card" + (items.length - 1), items.length - 1);

      return () => {
        // Cleanup handled by gsap.matchMedia()
      };
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGalleryAnimation);
  } else {
    initGalleryAnimation();
  }
</script>

---
const images = [
  "/images/about/IMG-20240725-WA0001.webp",
  "/images/about/IMG-20240725-WA0021.webp",
  "/images/about/IMG-20240725-WA0024.webp",
  "/images/about/IMG-20240725-WA0026.webp",
  "/images/about/IMG-20240725-WA0036.webp",
  "/images/about/IMG-20240725-WA0052.webp",
  "/images/about/IMG-20240725-WA0057.webp",
  "/images/about/IMG-20240725-WA0059.webp",
  "/images/about/IMG-20240725-WA0061.webp",
  "/images/about/IMG-20240725-WA0066.webp",
  "/images/about/Chiba-25.webp",
  "/images/about/557739044.webp",
  "/images/about/557739065.webp",
  "/images/about/622936369.webp",
  "/images/about/736420433.webp",
  "/images/about/736420508.webp",
  "/images/about/736420520.webp",
  "/images/about/736420746.webp",
  "/images/about/736420785.webp"
];
---
<section id="gallery" class="gallery-section">
  <!-- Desktop: Full-page Fan Carousel -->
  <div class="gallery-carousel-fan-container desktop-carousel">
    <div class="gallery-carousel-fan">
      {images.map(src => (
        <div class="carousel-item">
          <img src={src} alt="Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>

  <!-- Mobile: Horizontal Gallery -->
  <div class="horiz-gallery-wrapper mobile-gallery" id="portfolio">
    <div class="horiz-gallery-strip">
      {images.map(src => (
        <div class="horiz-item">
          <img src={src} alt="Chalet Chiba" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Base Desktop Styles */
  .mobile-gallery {
    display: none;
  }
  .desktop-carousel {
    display: block;
  }
  .gallery-carousel-fan-container {
    position: relative;
    width: 100%;
    height: 525px;
    overflow: visible;
    margin-top: -55px;
  }
  
  /* Mobile Styles */
  @media (max-width: 768px) {
    .desktop-carousel {
      display: none;
    }
    .mobile-gallery {
      display: flex; /* Use flex to center things naturally */
      flex-direction: column;
      justify-content: center;
      width: 100%;
      height: 100svh; /* svh is better for mobile browsers */
      overflow: hidden;
      position: relative;
    }
    .horiz-gallery-strip {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      padding: 0 1.5rem;
      width: fit-content;
      /* Removed will-change: transform to fix iOS cutting off images on long strips */
    }
    .horiz-item {
      flex-shrink: 0;
      width: 80vw;
      height: 60svh;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
      /* Use hardware acceleration on the items instead of the parent strip */
      transform: translateZ(0); 
    }
    .horiz-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initGalleryAnimation() {
    let mm = gsap.matchMedia();

    // Desktop: Fan Carousel
    mm.add("(min-width: 769px)", () => {
      const section = document.querySelector('.desktop-carousel');
      const items = section?.querySelectorAll('.carousel-item');
      let intervalId: any;

      if (items && items.length > 0) {
        let currentIndex = Math.floor(items.length / 2);

        function updateCarousel() {
          items.forEach((item, index) => {
            const el = item as HTMLElement;
            let offset = index - currentIndex;
            const total = items.length;
            let pos = (offset + total) % total;
            if (pos > Math.floor(total / 2)) {
              pos = pos - total;
            }

            const isCenter = pos === 0;
            const isAdjacent = Math.abs(pos) === 1;
            const isFar = Math.abs(pos) > 1;

            el.style.transform = `
              translateX(${pos * 100}%) 
              translateY(0%)
              translateZ(0px)
              rotate(0deg)
              scale(${isCenter ? 1 : isAdjacent ? 0.85 : 0.7})
            `;
            
            el.style.zIndex = isCenter ? '10' : isAdjacent ? '5' : '1';
            el.style.opacity = isCenter ? '1' : isAdjacent ? '0.7' : '0.4';
            el.style.filter = isCenter ? 'blur(0px)' : isAdjacent ? 'blur(3px)' : 'blur(6px)';
            el.style.visibility = Math.abs(pos) > 2 ? 'hidden' : 'visible';
          });
        }

        function handleNext() {
          currentIndex = (currentIndex + 1) % items.length;
          updateCarousel();
        }

        updateCarousel();
        intervalId = setInterval(handleNext, 4000);
      }

      return () => {
        if (intervalId) clearInterval(intervalId);
      };
    });

    // Mobile: Horizontal Scroll Gallery
    mm.add("(max-width: 768px)", () => {
      const horizontalSections = gsap.utils.toArray(".horiz-gallery-wrapper");

      horizontalSections.forEach(function (sec: any) {
        const pinWrap = sec.querySelector(".horiz-gallery-strip");
        if (!pinWrap) return;

        let pinWrapWidth: number;
        let horizontalScrollLength: number;

        function refresh() {
          pinWrapWidth = pinWrap.scrollWidth;
          horizontalScrollLength = pinWrapWidth - window.innerWidth;
        }

        refresh();

        // Pinning and horizontal scrolling
        gsap.to(pinWrap, {
          scrollTrigger: {
            scrub: 1, // Smooth scrub
            trigger: sec,
            pin: true, // Use true instead of sec for better default behavior
            start: "center center",
            // Divide the scroll distance by 2 so it doesn't take 15 screens to scroll through
            end: () => `+=${pinWrapWidth / 2}`,
            invalidateOnRefresh: true,
            // Add a small padding to pin spacer if needed, but native is usually fine
          },
          x: () => -horizontalScrollLength,
          ease: "none"
        });

        ScrollTrigger.addEventListener("refreshInit", refresh);
      });

      return () => {
        // Cleanup listener on unmatch
        // ScrollTrigger automatically cleans up its triggers
      };
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGalleryAnimation);
  } else {
    initGalleryAnimation();
  }
</script>

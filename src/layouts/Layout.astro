		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content="Retrage-te în inima Munților Bucegi la Chalet Chiba. Confort premium, peisaje spectaculoase și experiențe montane autentice în Carpații României. Rezervă acum o escapadă de neuitat!" />
		<meta name="keywords" content="Chalet Chiba, Cabana Chiba, cazare Bucegi, chalet munte Romania, cabana de inchiriat, munti, relaxare, cazare premium" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Retrage-te în inima Munților Bucegi la Chalet Chiba. Confort premium, peisaje spectaculoase și cazare autentică în Carpații României." />

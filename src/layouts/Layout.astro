			// Expose translations cache globally for component scripts to access
			(window as any).translationsCache = translations;

			function updateLanguage(lang) {
				localStorage.setItem('lang', lang);
				document.documentElement.lang = lang;

				document.querySelectorAll('[data-i18n]').forEach(el => {
					const key = el.getAttribute('data-i18n');
					if (translations[lang] && translations[lang][key]) {
						// If translation content has HTML tags (like <a>), always use innerHTML directly on the element
						if (translations[lang][key].indexOf('<') !== -1) {
							el.innerHTML = translations[lang][key];
						} else {
							const link = el.querySelector('a');
							if (link) {
								link.innerHTML = translations[lang][key];
							} else {
								el.innerHTML = translations[lang][key];
							}
						}
					}
				});

				if (translations[lang] && translations[lang]['document.title']) {
					const transTitle = translations[lang]['document.title'];
					document.title = transTitle;
					
					// Update OpenGraph Title
					const ogTitleEl = document.getElementById('og-title');
					if (ogTitleEl) {
						ogTitleEl.setAttribute('content', transTitle);
					}
				}

				if (translations[lang] && translations[lang]['document.description']) {
					const transDesc = translations[lang]['document.description'];
					
					// Update Meta Description
					const metaDescEl = document.getElementById('meta-description');
					if (metaDescEl) {
						metaDescEl.setAttribute('content', transDesc);
					}
					
					// Update OpenGraph Description
					const ogDescEl = document.getElementById('og-description');
					if (ogDescEl) {
						ogDescEl.setAttribute('content', transDesc);
					}
				}

				document.querySelectorAll('.lang-btn').forEach(btn => {
					if (btn.getAttribute('data-lang') === lang) {
						btn.classList.add('active');
					} else {
						btn.classList.remove('active');
					}
				});
				window.dispatchEvent(new CustomEvent('langChanged', { detail: lang }));
			}

			// Apply language choice as early as possible (Astro module scripts run after HTML is parsed)
			const defaultLang = localStorage.getItem('lang') || 'ro';
			updateLanguage(defaultLang);

			// Setup button click events
			document.querySelectorAll('.lang-btn').forEach(btn => {
				btn.addEventListener('click', () => {
					const selectedLang = btn.getAttribute('data-lang');
					if (selectedLang) {
						updateLanguage(selectedLang);
					}
				});
			});
		</script>

		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=5" />
		
		<!-- Preload the hero poster to eliminate any millisecond flashes -->
		<link rel="preload" as="image" href="/hero-poster.jpg" fetchpriority="high" />
		
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" id="meta-description" content="Retrage-te în inima Munților Bucegi la Chalet Chiba. Confort premium, peisaje spectaculoase și experiențe montane autentice în Carpații României. Rezervă acum o escapadă de neuitat!" />
		<meta name="keywords" content="Chalet Chiba, Cabana Chiba, cazare Bucegi, chalet munte Romania, cabana de inchiriat, munti, relaxare, cazare premium, Brasov, Timisu de Jos" />
		
		<!-- Canonical URL -->
		<link rel="canonical" id="canonical-url" href="https://chaletchiba.ro/" />

		<!-- Open Graph / Facebook / WhatsApp Share Preview -->
		<meta property="og:type" content="website" />
		<meta property="og:title" id="og-title" content={title} />
		<meta property="og:description" id="og-description" content="Retrage-te în inima Munților Bucegi la Chalet Chiba. Confort premium, peisaje spectaculoase și cazare autentică în Carpații României." />
		<meta property="og:image" content="/hero-cabana-cropped.webp" />
		
		<!-- Twitter Cards -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Chalet Chiba" />
		<meta name="twitter:description" content="O escapadă montană autentică lângă Brașov. Confort modern combinat cu peisaje pitorești." />
		<meta name="twitter:image" content="/hero-cabana-cropped.webp" />

		<!-- SEO Multi-language alternates (hreflang) -->
		<link rel="alternate" hreflang="ro" href="https://chaletchiba.ro/" />
		<link rel="alternate" hreflang="en" href="https://chaletchiba.ro/?lang=en" />
		<link rel="alternate" hreflang="de" href="https://chaletchiba.ro/?lang=de" />
		<link rel="alternate" hreflang="x-default" href="https://chaletchiba.ro/" />

